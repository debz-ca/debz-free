RUNNING_PROCS = {}

PRO_ONLY_ACTIONS = {
    "spawn", "golden", "cluster_deploy", "wg_peer_add", "wg_peer_remove",
    "wg_info", "node_list", "node_register", "node_poof", "apply_role",
    "salt_highstate", "salt_apply", "ansible_run", "k8s_join",
    "vm_list", "vm_start", "vm_stop", "vm_destroy", "vm_clone",
    "service_action", "credential_list", "credential_add",
    "proxmox_list", "firewall_rule", "cluster_info",
}

async def _pro_required(websocket, action: str) -> bool:
    """Return True (and send error) if this is a free edition trying a pro action."""
    if EDITION == "free" and action in PRO_ONLY_ACTIONS:
        await websocket.send(json.dumps({
            "type": "error",
            "msg": f"'{action}' requires debz Pro. Upgrade at debz.ca/upgrade.",
            "pro_required": True,
        }))
        return True
    return False

async def ws_handler(websocket):
    LOG.info("WebSocket client connected: %s", websocket.remote_address)
    try:
        async for raw in websocket:
            try:
                msg = json.loads(raw)
            except json.JSONDecodeError:
                await websocket.send(json.dumps({"type": "error", "msg": "invalid JSON"}))
                continue

            action = msg.get("action", "")
            LOG.info("WS action: %s", action)
            try:
                if await _pro_required(websocket, action):
                    continue
                if action == "ping":
                    await websocket.send(json.dumps({"type": "pong"}))
                elif action == "system_info":
                    await websocket.send(json.dumps({
                        "type": "system_info",
                        "data": get_system_info(),
                    }))
                elif action == "list_disks":
                    await websocket.send(json.dumps({
                        "type": "disk_list",
                        "disks": get_disks(),
                    }))
                elif action == "install":
                    await _run_install(websocket, msg)
                elif action == "wipe_disk":
                    await _run_wipe_disk(websocket, msg)
                elif action == "spawn":
                    await _run_spawn(websocket, msg)
                elif action == "golden":
                    await _run_golden(websocket, msg)
                elif action == "tail_log":
                    log_name = msg.get("log", "installer")
                    log_path = LOG_FILES.get(log_name, LOG_FILES["installer"])
                    await _tail_log(websocket, log_path)
                elif action == "list_vms":
                    await _list_vms(websocket)
                elif action == "vm_op":
                    await _vm_op(websocket, msg)
                elif action == "zfs_list":
                    await _zfs_list(websocket)
                elif action == "k8s_nodes":
                    await _k8s_nodes(websocket)
                elif action == "salt_status":
                    await _salt_status(websocket)
                elif action == "wg_status":
                    await websocket.send(json.dumps({
                        "type": "wg_data",
                        "data": get_wg_status(),
                    }))
                elif action == "wg_gen_keypair":
                    await _wg_gen_keypair(websocket)
                elif action == "wg_add_peer":
                    await _wg_add_peer(websocket, msg)
                elif action == "wg_remove_peer":
                    await _wg_remove_peer(websocket, msg)
                elif action == "golden_status":
                    await websocket.send(json.dumps({
                        "type": "golden_status",
                        "status": get_golden_status(),
                    }))
                elif action == "stamp":
                    await _run_stamp(websocket, msg)
                elif action == "k8s_join":
                    await _run_k8s_join(websocket, msg)
                elif action == "salt_highstate":
                    await _run_salt_highstate(websocket, msg)
                elif action == "salt_accept_all":
                    await _salt_accept_all(websocket)
                elif action == "node_list":
                    await _node_list(websocket)
                elif action == "node_apply":
                    await _node_apply(websocket, msg)
                elif action == "mine_refresh":
                    await _mine_refresh(websocket, msg)
                elif action == "node_accept_key":
                    await _node_accept_key(websocket, msg)
                elif action == "poof":
                    await _run_poof(websocket, msg)
                elif action == "cluster_deploy":
                    await _run_cluster_deploy(websocket, msg)
                elif action == "run_audit":
                    await _run_audit(websocket)
                elif action == "credentials_load":
                    creds = _load_credentials()
                    # Mask secrets before sending to browser
                    masked = json.loads(json.dumps(creds))
                    for p in masked.get("proxmox", []):
                        if p.get("token_secret"):
                            p["token_secret"] = "••••••••"
                    if masked.get("aws", {}).get("secret"):
                        masked["aws"]["secret"] = "••••••••"
                    if masked.get("azure", {}).get("client_secret"):
                        masked["azure"]["client_secret"] = "••••••••"
                    await websocket.send(json.dumps({"type": "credentials_data", "creds": masked}))
                elif action == "credentials_save":
                    # Merge: if secret field is masked placeholder, keep existing value
                    existing = _load_credentials()
                    incoming = msg.get("creds", {})
                    # Proxmox: match by id, preserve secret if masked
                    for i, p in enumerate(incoming.get("proxmox", [])):
                        if p.get("token_secret") == "••••••••":
                            for ep in existing.get("proxmox", []):
                                if ep.get("id") == p.get("id"):
                                    p["token_secret"] = ep.get("token_secret", "")
                    # AWS
                    if incoming.get("aws", {}).get("secret") == "••••••••":
                        incoming["aws"]["secret"] = existing.get("aws", {}).get("secret", "")
                    # Azure
                    if incoming.get("azure", {}).get("client_secret") == "••••••••":
                        incoming["azure"]["client_secret"] = existing.get("azure", {}).get("client_secret", "")
                    _save_credentials(incoming)
                    await websocket.send(json.dumps({"type": "credentials_saved"}))
                elif action == "credentials_test":
                    provider = msg.get("provider", "")
                    creds = _load_credentials()
                    ok, err = False, "unknown provider"
                    if provider == "proxmox":
                        pid = msg.get("id", "")
                        for p in creds.get("proxmox", []):
                            if p.get("id") == pid:
                                try:
                                    import urllib.request, urllib.error
                                    url = f"https://{p['host']}:{p.get('port',8006)}/api2/json/version"
                                    req = urllib.request.Request(url,
                                        headers={"Authorization": f"PVEAPIToken={p['token_id']}={p['token_secret']}"},
                                    )
                                    import ssl as _ssl
                                    ctx = _ssl.create_default_context()
                                    ctx.check_hostname = False
                                    ctx.verify_mode = _ssl.CERT_NONE
                                    urllib.request.urlopen(req, context=ctx, timeout=5)
                                    ok, err = True, ""
                                except Exception as e:
                                    ok, err = False, str(e)
                    await websocket.send(json.dumps({"type": "credentials_test_result",
                                                      "provider": provider, "ok": ok, "err": err}))
                elif action == "wg_planes_list":
                    await _wg_planes_list(websocket)
                elif action == "wg_plane_create":
                    await _wg_plane_create(websocket, msg)
                elif action == "wg_plane_delete":
                    await _wg_plane_delete(websocket, msg)
                elif action == "db_list":
                    type_ = msg.get("db_type") or None
                    items = db_list_templates(type_)
                    await websocket.send(json.dumps({
                        "type": "db_list", "db_type": type_, "items": items,
                    }))
                elif action == "db_save":
                    id_ = db_save_template(
                        msg.get("db_type", "generic"),
                        msg.get("name", "Untitled"),
                        msg.get("description", ""),
                        msg.get("data", {}),
                    )
                    db_log_event("save", id_,
                        f"Saved {msg.get('db_type','?')} template: {msg.get('name','?')}")
                    await websocket.send(json.dumps({
                        "type": "db_saved", "id": id_,
                        "name": msg.get("name"), "db_type": msg.get("db_type"),
                    }))
                elif action == "db_load":
                    tpl = db_load_template(msg.get("id", ""))
                    if tpl:
                        await websocket.send(json.dumps({"type": "db_loaded", "template": tpl}))
                    else:
                        await websocket.send(json.dumps({"type": "error", "msg": "template not found"}))
                elif action == "db_delete":
                    db_delete_template(msg.get("id", ""))
                    db_log_event("delete", msg.get("id", ""), "Template deleted")
                    await websocket.send(json.dumps({"type": "db_deleted", "id": msg.get("id")}))
                elif action == "db_node_register":
                    id_ = db_register_node(
                        msg.get("hostname", "unknown"),
                        role=msg.get("role", "unknown"),
                        ip_mgmt=msg.get("ip_mgmt", ""),
                        ip_wg0=msg.get("ip_wg0", ""),
                        ip_wg1=msg.get("ip_wg1", ""),
                        ip_wg2=msg.get("ip_wg2", ""),
                        ip_wg3=msg.get("ip_wg3", ""),
                        wg_pubkey=msg.get("wg_pubkey", ""),
                        cluster_id=msg.get("cluster_id", ""),
                        facts=msg.get("facts", {}),
                    )
                    db_log_event("node_join", id_, f"Node registered: {msg.get('hostname')}")
                    await websocket.send(json.dumps({"type": "db_node_registered", "id": id_}))
                elif action == "db_nodes":
                    nodes = db_list_nodes()
                    await websocket.send(json.dumps({"type": "db_nodes", "nodes": nodes}))
                elif action == "db_events":
                    events = db_list_events(msg.get("limit", 100))
                    await websocket.send(json.dumps({"type": "db_events", "events": events}))
                elif action == "service_list":
                    svcs = db_list_services(msg.get("cluster_id") or None)
                    await websocket.send(json.dumps({"type": "service_list", "services": svcs}))
                elif action == "service_save":
                    id_ = db_save_service(
                        msg.get("name", "unnamed"),
                        description  = msg.get("description", ""),
                        cluster_id   = msg.get("cluster_id", ""),
                        node_targets = msg.get("node_targets", []),
                        dataset      = msg.get("dataset", ""),
                        image        = msg.get("image", ""),
                        runtime      = msg.get("runtime", "systemd"),
                        replicas     = msg.get("replicas", 1),
                        repl_targets = msg.get("repl_targets", []),
                        config       = msg.get("config", {}),
                        salt_state   = msg.get("salt_state", ""),
                    )
                    db_log_event("service_save", id_, f"Service saved: {msg.get('name')}")
                    await websocket.send(json.dumps({"type": "service_saved", "id": id_}))
                elif action == "service_load":
                    svc = db_load_service(msg.get("id", ""))
                    if svc:
                        await websocket.send(json.dumps({"type": "service_data", "service": svc}))
                    else:
                        await websocket.send(json.dumps({"type": "error", "msg": "service not found"}))
                elif action == "service_delete":
                    db_delete_service(msg.get("id", ""))
                    db_log_event("service_delete", msg.get("id",""), "Service deleted")
                    await websocket.send(json.dumps({"type": "service_deleted", "id": msg.get("id")}))
                elif action == "service_deploy":
                    await _service_deploy(websocket, msg)
                elif action == "db_export":
                    export = db_export_all()
                    await websocket.send(json.dumps({"type": "db_export", "data": export}))
                elif action == "db_import":
                    counts = db_import_all(msg.get("data", {}), merge=msg.get("merge", True))
                    db_log_event("db_import", "system", f"DB import: {counts}")
                    await websocket.send(json.dumps({"type": "db_imported", "counts": counts}))
                elif action == "ui_mode":
                    live = is_live_mode()
                    nenv = get_node_env()
                    role = nenv.get("DEBZ_NODE_ROLE", "live" if live else "node")
                    ui_title = nenv.get("DEBZ_UI_TITLE", "debz")
                    hostname = nenv.get("DEBZ_NODE_HOSTNAME", "")
                    await websocket.send(json.dumps({
                        "type": "ui_mode",
                        "live": live,
                        "role": role,
                        "ui_title": ui_title,
                        "hostname": hostname,
                        "db_path": str(DB_PATH),
                        "db_exists": DB_PATH.exists(),
                        "db_size_kb": round(DB_PATH.stat().st_size / 1024, 1) if DB_PATH.exists() else 0,
                    }))
                elif action == "infra_status":
                    clusters = db_list_clusters()
                    nodes    = db_list_nodes()
                    vms      = db_list_vms()
                    events   = db_list_events(50)
                    # Augment nodes with live virsh VM count per host
                    vm_counts = {}
                    try:
                        out = subprocess.check_output(["virsh", "list", "--all", "--name"],
                                                       text=True, stderr=subprocess.DEVNULL)
                        vm_counts["localhost"] = len([l for l in out.strip().splitlines() if l.strip()])
                    except Exception:
                        pass
                    await websocket.send(json.dumps({
                        "type": "infra_status",
                        "clusters": clusters,
                        "nodes": nodes,
                        "vms": vms,
                        "events": events,
                        "vm_counts": vm_counts,
                    }))
                elif action == "cluster_save":
                    # Save a cluster definition to DB (called from Cluster Designer deploy flow)
                    id_ = db_upsert_cluster(
                        msg.get("name", "unnamed"),
                        msg.get("data", {}),
                        template_id=msg.get("template_id", ""),
                        status=msg.get("status", "designing"),
                    )
                    db_log_event("cluster_save", id_, f"Cluster saved: {msg.get('name')}")
                    await websocket.send(json.dumps({"type": "cluster_saved", "id": id_}))
                elif action == "vm_clone":
                    await _vm_clone(websocket, msg)
                elif action == "vm_replace":
                    await _vm_replace(websocket, msg)

                # ── Free-edition actions (ZFS / snapshots / logs) ──────────────
                elif action == "zfs_status":
                    try:
                        out = subprocess.check_output(
                            ["zpool", "status", "-v"], text=True, stderr=subprocess.STDOUT)
                    except Exception as e:
                        out = str(e)
                    await websocket.send(json.dumps({"type": "zfs_status", "output": out}))

                elif action == "snapshot_list":
                    try:
                        out = subprocess.check_output(
                            ["zfs", "list", "-t", "snapshot", "-o", "name,used", "-H"],
                            text=True, stderr=subprocess.STDOUT)
                        snaps = []
                        for line in out.strip().splitlines():
                            parts = line.split('\t')
                            if len(parts) >= 2:
                                snaps.append({"name": parts[0], "used": parts[1]})
                    except Exception:
                        snaps = []
                    await websocket.send(json.dumps({"type": "snapshot_list", "snapshots": snaps}))

                elif action == "snapshot_take":
                    import datetime as _dt
                    ts = _dt.datetime.now().strftime("%Y%m%d-%H%M%S")
                    try:
                        subprocess.check_call(
                            ["zfs", "snapshot", "-r", f"rpool@manual-{ts}"],
                            stderr=subprocess.DEVNULL)
                        await websocket.send(json.dumps({"type": "snapshot_done", "ts": ts}))
                    except Exception as e:
                        await websocket.send(json.dumps({"type": "error", "msg": str(e)}))

                elif action == "snapshot_rollback":
                    snap = msg.get("name", "")
                    try:
                        subprocess.check_call(
                            ["zfs", "rollback", "-r", snap],
                            stderr=subprocess.DEVNULL)
                        await websocket.send(json.dumps({"type": "snapshot_done", "name": snap}))
                    except Exception as e:
                        await websocket.send(json.dumps({"type": "error", "msg": str(e)}))

                elif action == "be_list":
                    try:
                        out = subprocess.check_output(
                            ["/usr/lib/debz-installer/backend/bin/debz-be", "list"],
                            text=True, stderr=subprocess.STDOUT)
                    except Exception as e:
                        out = str(e)
                    await websocket.send(json.dumps({"type": "be_list", "output": out}))

                elif action == "be_create":
                    name = msg.get("name", "")
                    try:
                        subprocess.check_call(
                            ["/usr/lib/debz-installer/backend/bin/debz-be", "create", name],
                            stderr=subprocess.DEVNULL)
                        await websocket.send(json.dumps({"type": "be_list", "output": f"Created: {name}"}))
                    except Exception as e:
                        await websocket.send(json.dumps({"type": "error", "msg": str(e)}))

                elif action == "read_log":
                    key = msg.get("log", "firstboot")
                    log_path = LOG_FILES.get(key, f"/var/log/debz/{key}.log")
                    try:
                        content = Path(log_path).read_text(errors="replace")[-32768:]
                    except Exception:
                        content = f"(log not found: {log_path})"
                    await websocket.send(json.dumps({"type": "log_content", "key": key, "content": content}))

                elif action == "network_info":
                    ifaces = []
                    try:
                        out = subprocess.check_output(["ip", "-j", "addr"], text=True)
                        import json as _json
                        for iface in _json.loads(out):
                            name = iface.get("ifname", "")
                            up   = iface.get("operstate", "") in ("UP", "UNKNOWN")
                            addrs = [a.get("local", "") for a in iface.get("addr_info", [])
                                     if a.get("family") in ("inet", "inet6")]
                            ifaces.append({"name": name, "up": up, "addr": ", ".join(addrs)})
                    except Exception:
                        pass
                    await websocket.send(json.dumps({"type": "network_info", "interfaces": ifaces}))

                elif action == "ansible_run":
                    pb     = msg.get("playbook", "")
                    limit  = msg.get("limit", "localhost")
                    extra  = msg.get("extra_vars", {})
                    import json as _json
                    cmd = ["ansible-playbook", pb, "-i", "localhost,",
                           "--connection", "local", "-l", limit]
                    if extra:
                        cmd += ["--extra-vars", _json.dumps(extra)]
                    await _stream_proc(websocket, cmd, target="ansible_log")

                else:
                    await websocket.send(json.dumps({
                        "type": "error",
                        "msg": f"unknown action: {action}",
                    }))
            except Exception as _action_err:
                LOG.exception("Error handling action %s", action)
                try:
                    await websocket.send(json.dumps({
                        "type": "error",
                        "msg": f"action '{action}' failed: {_action_err}",
                    }))
                except Exception:
                    pass

    except websockets.exceptions.ConnectionClosed:
        LOG.info("WebSocket client disconnected")

async def _wg_gen_keypair(websocket):
    """Generate a fresh WireGuard keypair and return it to the client."""
    try:
        privkey = subprocess.check_output(["wg", "genkey"], text=True).strip()
        pubkey  = subprocess.check_output(["wg", "pubkey"], input=privkey, text=True).strip()
        await websocket.send(json.dumps({
            "type": "wg_keypair",
            "privkey": privkey,
            "pubkey":  pubkey,
        }))
    except Exception as exc:
        await websocket.send(json.dumps({"type": "error", "msg": f"wg genkey failed: {exc}"}))


async def _wg_add_peer(websocket, msg):
    """Add a peer to one or all WireGuard interfaces live via wg set.

    Expected msg fields:
      iface       - "wg0"|"wg1"|"wg2"|"wg3"|"all"
      pubkey      - peer's public key
      allowed_ips - CIDR(s) comma-separated, e.g. "10.77.100.5/32"
      endpoint    - optional "host:port"
    """
    iface       = msg.get("iface", "wg1")
    pubkey      = msg.get("pubkey", "").strip()
    allowed_ips = msg.get("allowed_ips", "").strip()
    endpoint    = msg.get("endpoint", "").strip()

    if not pubkey or not allowed_ips:
        await websocket.send(json.dumps({"type": "error", "msg": "wg_add_peer: pubkey and allowed_ips required"}))
        return

    targets = ["wg0", "wg1", "wg2", "wg3"] if iface == "all" else [iface]
    results = []
    for intf in targets:
        cmd = ["wg", "set", intf, "peer", pubkey, "allowed-ips", allowed_ips]
        if endpoint:
            cmd += ["endpoint", endpoint]
        try:
            subprocess.check_call(cmd, stderr=subprocess.DEVNULL)
            # Persist to wg-quick config if it exists
            conf = f"/etc/wireguard/{intf}.conf"
            if os.path.exists(conf):
                peer_block = f"\n[Peer]\nPublicKey = {pubkey}\nAllowedIPs = {allowed_ips}\n"
                if endpoint:
                    peer_block += f"Endpoint = {endpoint}\n"
                with open(conf, "a") as f:
                    f.write(peer_block)
            results.append({"iface": intf, "ok": True})
        except Exception as exc:
            results.append({"iface": intf, "ok": False, "error": str(exc)})

    await websocket.send(json.dumps({"type": "wg_add_peer_result", "results": results}))
    # Push updated status
    await websocket.send(json.dumps({"type": "wg_data", "data": get_wg_status()}))


async def _wg_remove_peer(websocket, msg):
    """Remove a peer from one or all WireGuard interfaces live via wg set.

    Expected msg fields:
      iface  - "wg0"|"wg1"|"wg2"|"wg3"|"all"
      pubkey - peer's public key to remove
    """
    iface  = msg.get("iface", "wg1")
    pubkey = msg.get("pubkey", "").strip()

    if not pubkey:
        await websocket.send(json.dumps({"type": "error", "msg": "wg_remove_peer: pubkey required"}))
        return

    targets = ["wg0", "wg1", "wg2", "wg3"] if iface == "all" else [iface]
    results = []
    for intf in targets:
        try:
            subprocess.check_call(
                ["wg", "set", intf, "peer", pubkey, "remove"],
                stderr=subprocess.DEVNULL
            )
            # Remove from wg-quick config if it exists
            conf = f"/etc/wireguard/{intf}.conf"
            if os.path.exists(conf):
                with open(conf, "r") as f:
                    content = f.read()
                # Strip the [Peer] block that contains this pubkey
                import re as _re
                content = _re.sub(
                    r"\[Peer\][^\[]*PublicKey\s*=\s*" + _re.escape(pubkey) + r"[^\[]*",
                    "", content, flags=_re.DOTALL
                )
                with open(conf, "w") as f:
                    f.write(content)
            results.append({"iface": intf, "ok": True})
        except Exception as exc:
            results.append({"iface": intf, "ok": False, "error": str(exc)})

    await websocket.send(json.dumps({"type": "wg_remove_peer_result", "results": results}))
    await websocket.send(json.dumps({"type": "wg_data", "data": get_wg_status()}))


async def _stream_proc(websocket, cmd, env=None, target="log"):
    """Run a command, stream stdout/stderr lines to websocket."""
    await websocket.send(json.dumps({"type": "exec_start", "cmd": str(cmd), "target": target}))
    proc = await asyncio.create_subprocess_exec(
        *cmd,
        stdin=asyncio.subprocess.DEVNULL,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.STDOUT,
        env={**os.environ, **(env or {})},
    )
    async for line in proc.stdout:
        await websocket.send(json.dumps({
            "type": "log_line",
            "line": line.decode(errors="replace").rstrip(),
            "target": target,
        }))
    rc = await proc.wait()
    await websocket.send(json.dumps({"type": "exec_done", "rc": rc, "target": target}))
    return rc

async def _run_wipe_disk(websocket, msg):
    disk = msg.get("disk", "")
    if not re.match(r'^/dev/[a-z]{2,8}[0-9]{0,3}$', disk):
        await websocket.send(json.dumps({"type": "error", "msg": f"Invalid disk: {disk}"}))
        return
    # blkdiscard fast-zeroes SSD/NVMe; fall back to dd for spinning disks
    cmd = ["bash", "-c",
           f"blkdiscard -z {disk} 2>/dev/null || "
           f"dd if=/dev/zero of={disk} bs=1M status=progress 2>&1; "
           f"sync; echo 'Wipe complete.'"]
    await _stream_proc(websocket, cmd, target="install")

async def _run_install(websocket, msg):
    params = msg.get("params", {})
    # Map frontend 'role' → DEBZ_PROFILE (installer key)
    if "role" in params and "profile" not in params:
        params["profile"] = params.pop("role")
    answers = []
    for k, v in params.items():
        key = k.upper()
        if not key.startswith("DEBZ_"):
            key = f"DEBZ_{key}"
        answers.append(f"{key}={shlex.quote(str(v))}")

    answers_path = "/tmp/debz-webui-answers.env"
    with open(answers_path, "w") as f:
        f.write("\n".join(answers) + "\n")
    os.chmod(answers_path, 0o600)

    target = msg.get("_target", "install")
    await _stream_proc(websocket,
        ["/usr/local/bin/debz-install-target", "--config", answers_path],
        target=target)

async def _run_spawn(websocket, msg):
    params = msg.get("params", {})
    cmd = ["/usr/local/sbin/debz-spawn"]
    for k, v in params.items():
        cmd += [f"--{k.replace('_','-')}", str(v)]
    target = msg.get("_target", "spawn")
    await _stream_proc(websocket, cmd, target=target)

async def _run_golden(websocket, msg):
