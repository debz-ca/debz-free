    if not re.match(r'^(master|kvm|storage|vdi)$', template):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid template"}))
        return
    target = msg.get("_target", "golden")
    cmd = ["/usr/local/sbin/debz-golden", "--template", template]
    await _stream_proc(websocket, cmd, target=target)

async def _run_stamp(websocket, msg):
    template   = msg.get("template", "kvm")
    count      = int(msg.get("count", 1))
    base_index = int(msg.get("base_index", 1))
    color      = msg.get("color", "blue")
    if not re.match(r'^(master|kvm|storage|vdi|firewall|proxmox|monitoring|storage|worker|etcd|lb|landing)$', template):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid template"}))
        return
    if color not in ("blue", "green"):
        color = "blue"
    target     = msg.get("_target", "golden")
    golden_dir = Path("/var/lib/debz/golden")
    image_path = golden_dir / f"golden-{template}.qcow2"
    if not image_path.exists():
        await websocket.send(json.dumps({"type": "error", "msg": f"Golden image not found: {image_path}"}))
        return
    for i in range(count):
        idx      = base_index + i
        hostname = f"{template}-{idx:02d}"
        clone    = golden_dir / f"{hostname}.qcow2"
        # Create CoW clone
        rc = await _stream_proc(websocket,
            ["qemu-img", "create", "-f", "qcow2", "-b", str(image_path), "-F", "qcow2", str(clone)],
            target=target)
        if rc != 0:
            break
        # Stamp identity into clone
        rc = await _stream_proc(websocket,
            ["/usr/local/sbin/debz-stamp-identity",
             "--image",    str(clone),
             "--hostname", hostname,
             "--template", template,
             "--index",    str(idx),
             "--color",    color],
            target=target)
        if rc != 0:
            break

