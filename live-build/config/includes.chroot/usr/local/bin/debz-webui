#!/usr/bin/env python3
"""
debz-webui — lightweight web-based installer UI for Debz.
Serves a browser frontend and exposes a WebSocket API so the browser
can drive installs, spawns, and VM management without a terminal.

Usage:
  debz-webui [--port PORT] [--bind ADDR] [--no-browser]
"""
