    import yaml
except ImportError:
    yaml = None

try:
    import websockets
except ImportError:
    print("[debz-webui] Installing websockets...")
    subprocess.check_call([sys.executable, "-m", "pip", "install", "--quiet", "websockets"])
    import websockets

