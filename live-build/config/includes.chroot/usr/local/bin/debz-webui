def db_list_vms(cluster_id=None):
    con = _db_connect()
    if cluster_id:
        rows = con.execute("SELECT * FROM vms WHERE cluster_id=? ORDER BY role,name", (cluster_id,)).fetchall()
    else:
        rows = con.execute("SELECT * FROM vms ORDER BY cluster_id,role,name").fetchall()
    result = []
    for r in rows:
        d = dict(r)
        try: d["data"] = json.loads(d["data"])
        except Exception: d["data"] = {}
        result.append(d)
    con.close()
    return result

def db_upsert_cluster(name, data, template_id="", status="designing"):
    con = _db_connect()
    now = _db_now()
    row = con.execute("SELECT id FROM clusters WHERE name=?", (name,)).fetchone()
    if row:
        id_ = row["id"]
        con.execute(
            "UPDATE clusters SET data=?,template_id=?,status=?,updated_at=? WHERE id=?",
            (json.dumps(data), template_id, status, now, id_)
        )
    else:
        id_ = str(uuid.uuid4())
        con.execute(
            "INSERT INTO clusters (id,name,template_id,status,data,created_at,updated_at) VALUES (?,?,?,?,?,?,?)",
            (id_, name, template_id, status, json.dumps(data), now, now)
        )
    con.commit()
    con.close()
    return id_

def db_save_service(name, description="", cluster_id="", node_targets=None,
                    dataset="", image="", runtime="systemd", replicas=1,
                    repl_targets=None, config=None, salt_state=""):
    """Insert or update a service definition. Returns the id."""
    con = _db_connect()
    now = _db_now()
    row = con.execute("SELECT id FROM services WHERE name=?", (name,)).fetchone()
    data_args = (
        description, cluster_id,
        json.dumps(node_targets or []),
        dataset or f"rpool/services/{name}",
        image, runtime, replicas,
        json.dumps(repl_targets or []),
        json.dumps(config or {}),
        salt_state, now,
    )
    if row:
        id_ = row["id"]
        con.execute(
            "UPDATE services SET description=?,cluster_id=?,node_targets=?,dataset=?,"
            "image=?,runtime=?,replicas=?,repl_targets=?,config=?,salt_state=?,updated_at=? WHERE id=?",
            data_args + (id_,)
        )
    else:
        id_ = str(uuid.uuid4())
        con.execute(
            "INSERT INTO services (id,name,description,cluster_id,node_targets,dataset,"
            "image,runtime,replicas,repl_targets,config,salt_state,status,created_at,updated_at) "
            "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (id_, name) + data_args + ("defined", now,)
        )
    con.commit()
    con.close()
    return id_

def db_list_services(cluster_id=None):
    con = _db_connect()
    if cluster_id:
        rows = con.execute(
            "SELECT * FROM services WHERE cluster_id=? ORDER BY name", (cluster_id,)
        ).fetchall()
    else:
        rows = con.execute("SELECT * FROM services ORDER BY name").fetchall()
    result = []
    for r in rows:
        d = dict(r)
        for f in ("node_targets", "repl_targets", "config"):
            try: d[f] = json.loads(d[f])
            except Exception: d[f] = [] if f != "config" else {}
        result.append(d)
    con.close()
    return result

