    try:
        subprocess.check_call(
            ["salt-key", "-A", "-y"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        await websocket.send(json.dumps({"type": "log_line", "line": "All pending keys accepted.", "target": "log"}))
