logging.basicConfig(level=logging.INFO, format="[%(asctime)s] [webui] %(message)s",
                    datefmt="%Y-%m-%dT%H:%M:%S")

# Serve from edition-specific UI directory.
# build-iso.sh copies the right edition into 'active/' at build time.
# Fall back to base dir if active/ doesn't exist yet.
_WEBUI_BASE = Path("/usr/local/share/debz-webui")
_WEBUI_ACTIVE = _WEBUI_BASE / "active"
WEBUI_DIR = _WEBUI_ACTIVE if _WEBUI_ACTIVE.is_dir() else _WEBUI_BASE

EDITION = Path("/etc/debz/edition").read_text().strip() if Path("/etc/debz/edition").exists() else "free"
MANIFEST         = Path("/etc/debz/install-manifest.env")
CREDENTIALS_PATH = Path("/run/debz/credentials.json")
DB_PATH          = Path("/var/lib/debz/state.db")
LOG_FILES  = {
    "installer": "/var/log/installer/debz-installer.log",
    "storage":   "/var/log/installer/storage.log",
    "network":   "/var/log/installer/network.log",
    "bootstrap": "/var/log/installer/bootstrap.log",
    "snapshots": "/var/log/debz/snapshots.log",
    "firstboot": "/var/log/debz/firstboot.log",
    "autoboot":  "/var/log/debz/autobootstrap.log",
    "audit":     "/var/log/debz/audit.log",
}

# ── State database ─────────────────────────────────────────────────────────────

def _db_now():
    return datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")

def _db_connect():
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    con.execute("PRAGMA journal_mode=WAL")
    return con

def db_init():
    """Create state.db and all tables if not present."""
    DB_PATH.parent.mkdir(parents=True, exist_ok=True)
    con = _db_connect()
    con.executescript("""
    CREATE TABLE IF NOT EXISTS templates (
        id          TEXT PRIMARY KEY,
        type        TEXT NOT NULL,
        name        TEXT NOT NULL,
        description TEXT DEFAULT '',
        data        TEXT NOT NULL,
        created_at  TEXT NOT NULL,
        updated_at  TEXT NOT NULL
    );
    CREATE TABLE IF NOT EXISTS nodes (
        id          TEXT PRIMARY KEY,
        hostname    TEXT NOT NULL UNIQUE,
        role        TEXT DEFAULT 'unknown',
        ip_mgmt     TEXT DEFAULT '',
        ip_wg0      TEXT DEFAULT '',
        ip_wg1      TEXT DEFAULT '',
        ip_wg2      TEXT DEFAULT '',
        ip_wg3      TEXT DEFAULT '',
        wg_pubkey   TEXT DEFAULT '',
        cluster_id  TEXT DEFAULT '',
        status      TEXT DEFAULT 'unknown',
        last_seen   TEXT DEFAULT '',
        facts       TEXT DEFAULT '{}',
        created_at  TEXT NOT NULL
    );
    CREATE TABLE IF NOT EXISTS clusters (
        id          TEXT PRIMARY KEY,
        name        TEXT NOT NULL UNIQUE,
        template_id TEXT DEFAULT '',
        status      TEXT DEFAULT 'designing',
        data        TEXT NOT NULL,
        created_at  TEXT NOT NULL,
        updated_at  TEXT NOT NULL
    );
    CREATE TABLE IF NOT EXISTS vms (
        id          TEXT PRIMARY KEY,
        cluster_id  TEXT NOT NULL,
        node_id     TEXT DEFAULT '',
        name        TEXT NOT NULL,
        role        TEXT NOT NULL,
        cpu         INTEGER DEFAULT 2,
        ram_gb      INTEGER DEFAULT 4,
        disk_gb     INTEGER DEFAULT 64,
        status      TEXT DEFAULT 'defined',
        golden_src  TEXT DEFAULT '',
        ip_addr     TEXT DEFAULT '',
        wg_pubkey   TEXT DEFAULT '',
        last_seen   TEXT DEFAULT '',
        data        TEXT DEFAULT '{}',
        created_at  TEXT NOT NULL
    );
    CREATE TABLE IF NOT EXISTS events (
        id          INTEGER PRIMARY KEY AUTOINCREMENT,
        ts          TEXT NOT NULL,
        type        TEXT NOT NULL,
        subject     TEXT DEFAULT '',
        message     TEXT NOT NULL,
        data        TEXT DEFAULT '{}'
    );
    CREATE TABLE IF NOT EXISTS services (
        id           TEXT PRIMARY KEY,
        name         TEXT NOT NULL UNIQUE,
        description  TEXT DEFAULT '',
        cluster_id   TEXT DEFAULT '',
        node_targets TEXT DEFAULT '[]',
        dataset      TEXT DEFAULT '',
        image        TEXT DEFAULT '',
        runtime      TEXT DEFAULT 'systemd',
        status       TEXT DEFAULT 'defined',
        version      TEXT DEFAULT '',
        replicas     INTEGER DEFAULT 1,
        repl_targets TEXT DEFAULT '[]',
        config       TEXT DEFAULT '{}',
        salt_state   TEXT DEFAULT '',
        created_at   TEXT NOT NULL,
        updated_at   TEXT NOT NULL
    );
    """)
    con.commit()
    con.close()
    LOG.info("State DB ready: %s", DB_PATH)

def db_save_template(type_, name, description, data):
    """Insert or update a template by type+name. Returns the id."""
    con = _db_connect()
    now = _db_now()
    row = con.execute(
        "SELECT id FROM templates WHERE type=? AND name=?", (type_, name)
    ).fetchone()
    if row:
        id_ = row["id"]
        con.execute(
            "UPDATE templates SET description=?,data=?,updated_at=? WHERE id=?",
            (description, json.dumps(data), now, id_)
        )
    else:
        id_ = str(uuid.uuid4())
        con.execute(
            "INSERT INTO templates (id,type,name,description,data,created_at,updated_at) "
            "VALUES (?,?,?,?,?,?,?)",
            (id_, type_, name, description, json.dumps(data), now, now)
        )
    con.commit()
    con.close()
    return id_

def db_list_templates(type_=None):
    """List templates, optionally filtered by type, newest first."""
    con = _db_connect()
    if type_:
        rows = con.execute(
            "SELECT id,type,name,description,created_at,updated_at "
            "FROM templates WHERE type=? ORDER BY updated_at DESC", (type_,)
        ).fetchall()
    else:
        rows = con.execute(
            "SELECT id,type,name,description,created_at,updated_at "
            "FROM templates ORDER BY type,updated_at DESC"
        ).fetchall()
    result = [dict(r) for r in rows]
    con.close()
    return result

def db_load_template(id_):
    """Load a full template by id. Returns dict with data parsed, or None."""
    con = _db_connect()
    row = con.execute("SELECT * FROM templates WHERE id=?", (id_,)).fetchone()
    con.close()
    if not row:
        return None
    d = dict(row)
    try:
        d["data"] = json.loads(d["data"])
    except Exception:
        pass
    return d

def db_delete_template(id_):
    con = _db_connect()
    con.execute("DELETE FROM templates WHERE id=?", (id_,))
    con.commit()
    con.close()

def db_register_node(hostname, role="unknown", ip_mgmt="", ip_wg0="", ip_wg1="",
                     ip_wg2="", ip_wg3="", wg_pubkey="", cluster_id="", facts=None):
    """Upsert a node into the inventory. Returns the node id."""
    con = _db_connect()
    now = _db_now()
    facts_str = json.dumps(facts or {})
    row = con.execute("SELECT id FROM nodes WHERE hostname=?", (hostname,)).fetchone()
    if row:
        id_ = row["id"]
        con.execute(
            "UPDATE nodes SET role=?,ip_mgmt=?,ip_wg0=?,ip_wg1=?,ip_wg2=?,ip_wg3=?,"
            "wg_pubkey=?,cluster_id=?,status='online',last_seen=?,facts=? WHERE hostname=?",
            (role, ip_mgmt, ip_wg0, ip_wg1, ip_wg2, ip_wg3,
             wg_pubkey, cluster_id, now, facts_str, hostname)
        )
    else:
        id_ = str(uuid.uuid4())
        con.execute(
            "INSERT INTO nodes (id,hostname,role,ip_mgmt,ip_wg0,ip_wg1,ip_wg2,ip_wg3,"
            "wg_pubkey,cluster_id,status,last_seen,facts,created_at) "
            "VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
            (id_, hostname, role, ip_mgmt, ip_wg0, ip_wg1, ip_wg2, ip_wg3,
             wg_pubkey, cluster_id, "online", now, facts_str, now)
        )
    con.commit()
    con.close()
    return id_

def db_list_nodes():
    con = _db_connect()
    rows = con.execute(
        "SELECT * FROM nodes ORDER BY role,hostname"
    ).fetchall()
    result = []
    for r in rows:
        d = dict(r)
        try:    d["facts"] = json.loads(d["facts"])
        except Exception: d["facts"] = {}
        result.append(d)
    con.close()
    return result

def db_log_event(type_, subject, message, data=None):
    con = _db_connect()
    con.execute(
        "INSERT INTO events (ts,type,subject,message,data) VALUES (?,?,?,?,?)",
        (_db_now(), type_, subject, message, json.dumps(data or {}))
    )
    con.commit()
    con.close()

def db_list_events(limit=100):
    con = _db_connect()
    rows = con.execute(
        "SELECT * FROM events ORDER BY id DESC LIMIT ?", (limit,)
    ).fetchall()
    result = []
    for r in rows:
        d = dict(r)
        try:    d["data"] = json.loads(d["data"])
        except Exception: d["data"] = {}
        result.append(d)
    con.close()
    return result

