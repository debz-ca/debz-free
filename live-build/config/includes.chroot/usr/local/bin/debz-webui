async def _tail_log(websocket, log_path):
    if not os.path.exists(log_path):
        await websocket.send(json.dumps({
            "type": "log_content",
            "lines": [f"Log not found: {log_path}"],
        }))
        return
    try:
        out = subprocess.check_output(["tail", "-n", "200", log_path], text=True)
        lines = out.splitlines()
    except Exception as e:
        lines = [f"Error reading log: {e}"]
    await websocket.send(json.dumps({"type": "log_content", "lines": lines}))

async def _list_vms(websocket):
    vms = []
    try:
        out = subprocess.check_output(
            ["virsh", "list", "--all", "--name"], text=True,
            stderr=subprocess.DEVNULL
        )
        for name in out.strip().splitlines():
            name = name.strip()
            if not name:
                continue
            state = "unknown"
            try:
                s = subprocess.check_output(
                    ["virsh", "domstate", name], text=True,
                    stderr=subprocess.DEVNULL
                ).strip()
                state = s
            except Exception:
                pass
            vms.append({"name": name, "state": state})
    except Exception as e:
        LOG.warning("virsh list failed: %s", e)
    await websocket.send(json.dumps({"type": "vm_list", "vms": vms}))

async def _vm_op(websocket, msg):
    vm   = msg.get("vm", "")
    op   = msg.get("op", "")
    ops  = {"start": "virsh start", "stop": "virsh shutdown",
            "force-stop": "virsh destroy", "delete": "virsh undefine --nvram"}
    if op not in ops or not re.match(r'^[a-zA-Z0-9_\-]+$', vm):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid vm op"}))
        return
    cmd = shlex.split(f"{ops[op]} {vm}")
    await _stream_proc(websocket, cmd)

async def _zfs_list(websocket):
    pools, datasets = [], []
    try:
        out = subprocess.check_output(
            ["zpool", "list", "-H", "-o", "name,size,alloc,free,health"],
            text=True, stderr=subprocess.DEVNULL
        )
        for line in out.strip().splitlines():
            parts = line.split("\t")
            if len(parts) >= 5:
                pools.append({"name": parts[0], "size": parts[1],
                               "alloc": parts[2], "free": parts[3],
                               "health": parts[4]})
    except Exception:
        pass
    try:
        out = subprocess.check_output(
            ["zfs", "list", "-H", "-o", "name,used,avail,refer,mountpoint"],
            text=True, stderr=subprocess.DEVNULL
        )
        for line in out.strip().splitlines():
            parts = line.split("\t")
            if len(parts) >= 5:
                datasets.append({"name": parts[0], "used": parts[1],
                                  "avail": parts[2], "refer": parts[3],
                                  "mountpoint": parts[4]})
    except Exception:
        pass
    await websocket.send(json.dumps({"type": "zfs_data", "pools": pools, "datasets": datasets}))

async def _k8s_nodes(websocket):
    nodes = []
    try:
        cols = (
            "NAME:.metadata.name,"
            "STATUS:.status.conditions[-1].type,"
            "ROLE:.metadata.labels.node-role\\.kubernetes\\.io/control-plane,"
            "VERSION:.status.nodeInfo.kubeletVersion,"
            "WG2:.metadata.annotations.debz\\.ca/wg2-ip"
        )
        out = subprocess.check_output(
            ["kubectl", "get", "nodes", "-o",
             f"custom-columns={cols}", "--no-headers"],
            text=True, stderr=subprocess.DEVNULL,
            env={**os.environ, "KUBECONFIG": "/root/.kube/config"},
        )
        for line in out.strip().splitlines():
            parts = line.split()
            if parts:
                nodes.append({
                    "name":       parts[0],
                    "status":     parts[1] if len(parts) > 1 else "?",
                    "role":       "control-plane" if len(parts) > 2 and parts[2] not in ("<none>", "") else "worker",
                    "version":    parts[3] if len(parts) > 3 else "?",
                    "wg2_ip":     parts[4] if len(parts) > 4 and parts[4] != "<none>" else "—",
                    "api_server": "https://10.79.0.1:6443",
                })
    except Exception:
        pass
    await websocket.send(json.dumps({"type": "k8s_nodes", "nodes": nodes}))

async def _node_list(websocket):
    """Full node fleet: mine query + live ping, returns addressing table."""
    nodes = []
    pending_keys = []
    try:
        # Live ping — 5s timeout, non-fatal if salt not running
        ping_data = {}
        try:
            out = subprocess.check_output(
                ["salt", "*", "test.ping", "--out=json", "-t", "5"],
                text=True, stderr=subprocess.DEVNULL,
            )
            ping_data = json.loads(out)
        except Exception:
            pass

        # Grains: role, color, index, all four WireGuard IPs
        grains_data = {}
        try:
            g_out = subprocess.check_output(
                ["salt", "*", "grains.item",
                 "role", "color", "node_index",
                 "wg0_ip", "wg1_ip", "wg2_ip", "wg3_ip",
                 "--out=json", "-t", "5"],
                text=True, stderr=subprocess.DEVNULL,
            )
            grains_data = json.loads(g_out)
        except Exception:
            pass

        # Merge: any host that appears in grains OR ping
        all_hosts = set(grains_data.keys()) | set(ping_data.keys())
        for host in sorted(all_hosts):
            g = grains_data.get(host, {})
            color = g.get("color", "")
            index = g.get("node_index", "")
            # Derive IPs from index+color if grains not yet set
            if index and not g.get("wg0_ip"):
                octet3 = 100 if color == "blue" else 200
                g["wg0_ip"] = f"10.77.{octet3}.{index}"
                g["wg1_ip"] = f"10.78.{octet3}.{index}"
                g["wg2_ip"] = f"10.79.{octet3}.{index}"
                g["wg3_ip"] = f"10.80.{octet3}.{index}"
            nodes.append({
                "host":   host,
                "online": ping_data.get(host) is True,
                "role":   g.get("role", ""),
                "color":  color,
                "index":  str(index),
                "wg0":    g.get("wg0_ip", ""),
                "wg1":    g.get("wg1_ip", ""),
                "wg2":    g.get("wg2_ip", ""),
                "wg3":    g.get("wg3_ip", ""),
            })
    except Exception as e:
        LOG.warning("node_list failed: %s", e)

    # Pending keys
    try:
        k_out = subprocess.check_output(
            ["salt-key", "-l", "pre", "--out=json"],
            text=True, stderr=subprocess.DEVNULL,
        )
        pending_keys = json.loads(k_out).get("minions_pre", [])
    except Exception:
        pass

    await websocket.send(json.dumps({
        "type":    "node_list",
        "nodes":   nodes,
        "pending": pending_keys,
    }))


async def _node_apply(websocket, msg):
    """Apply a Salt state to a target minion (or grain match)."""
    salt_target = msg.get("target", "")
    state       = msg.get("state", "")
    ws_target   = msg.get("_target", "log")
    if not re.match(r'^[a-zA-Z0-9_\-\.\*]+$', salt_target):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid target"}))
        return
    if not re.match(r'^[a-zA-Z0-9_\.\-]+$', state):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid state"}))
        return
    cmd = ["salt", salt_target, "state.apply", state]
    await _stream_proc(websocket, cmd, target=ws_target)


