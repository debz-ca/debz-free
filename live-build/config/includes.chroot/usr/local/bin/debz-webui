    """Force all minions to update their mine data."""
    salt_target = msg.get("target", "*")
    if not re.match(r'^[a-zA-Z0-9_\-\.\*]+$', salt_target):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid target"}))
        return
    await _stream_proc(websocket, ["salt", salt_target, "mine.update"],
                       target=msg.get("_target", "log"))


async def _node_accept_key(websocket, msg):
    """Accept a specific pending Salt key by minion name."""
    name = msg.get("name", "")
    if not re.match(r'^[a-zA-Z0-9_\-\.]+$', name):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid key name"}))
        return
    try:
        subprocess.check_call(
            ["salt-key", "-a", name, "-y"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        await websocket.send(json.dumps({
            "type": "log_line", "line": f"Accepted key: {name}", "target": "log",
        }))
        # Immediately refresh node list
        await _node_list(websocket)
    except Exception as e:
        await websocket.send(json.dumps({"type": "error", "msg": str(e)}))


async def _salt_status(websocket):
    minions = []
    pending = 0
    try:
        out = subprocess.check_output(
            ["salt", "*", "test.ping", "--out=json", "-t", "5"],
            text=True, stderr=subprocess.DEVNULL
        )
        ping_data = json.loads(out)
        # Fetch grains for role/wg1_ip/node_index
        grains_data = {}
        try:
            g_out = subprocess.check_output(
                ["salt", "*", "grains.item", "role", "wg1_ip", "node_index",
                 "--out=json", "-t", "5"],
                text=True, stderr=subprocess.DEVNULL
            )
            grains_data = json.loads(g_out)
        except Exception:
            pass
        for host, ok in ping_data.items():
            g = grains_data.get(host, {})
            minions.append({
                "host":       host,
                "online":     ok is True,
                "role":       g.get("role", ""),
                "wg1_ip":     g.get("wg1_ip", ""),
                "node_index": g.get("node_index", ""),
            })
    except Exception:
        pass
    # Pending keys
    try:
        k_out = subprocess.check_output(
            ["salt-key", "-l", "pre", "--out=json"],
            text=True, stderr=subprocess.DEVNULL
        )
        k_data = json.loads(k_out)
        pending = len(k_data.get("minions_pre", []))
    except Exception:
        pass
    await websocket.send(json.dumps({
        "type": "salt_status",
        "minions": minions,
        "pending": pending,
    }))

async def _run_poof(websocket, msg):
    """Run debz-poof in live mode only; stream output then send poof_done."""
    live = True
    try:
        with open("/etc/debz/install-manifest.env") as f:
            if "DEBZ_INSTALLED=1" in f.read():
                live = False
    except Exception:
        pass
    if not live:
        await websocket.send(json.dumps({"type": "error", "msg": "poof only runs in live mode"}))
        return
    await _stream_proc(websocket, ["/usr/local/sbin/debz-poof"],
                       target=msg.get("_target", "log"))
    await websocket.send(json.dumps({"type": "poof_done"}))


async def _run_cluster_deploy(websocket, msg):
    cmd_type = msg.get("cmd", "")
    if cmd_type not in ("scc", "k8s-ha"):
        await websocket.send(json.dumps({"type": "error", "msg": "cmd must be scc or k8s-ha"}))
        return

    # Load saved credentials to resolve named targets
    all_creds = _load_credentials()
    px_by_id  = {p["id"]: p for p in all_creds.get("proxmox", [])}

    # Per-node target overrides: {"master": "px-123", "fw1": "px-456", ...}
    node_targets = msg.get("node_targets", {})
    # Default target (falls back to inline form values)
    default_px = {
        "host":         msg.get("proxmox_host",  ""),
        "node":         msg.get("proxmox_node",  "pve"),
        "token_id":     msg.get("token_id",      ""),
        "token_secret": msg.get("token_secret",  ""),
        "iso_storage":  msg.get("iso_storage",   "local"),
    }

    def _env_for_node(hostname):
        cid = node_targets.get(hostname)
        px  = px_by_id.get(cid, default_px) if cid else default_px
        return {
            "PROXMOX_HOST":         px.get("host",         default_px["host"]),
            "PROXMOX_NODE":         px.get("node",         default_px["node"]),
            "PROXMOX_TOKEN_ID":     px.get("token_id",     default_px["token_id"]),
            "PROXMOX_TOKEN_SECRET": px.get("token_secret", default_px["token_secret"]),
            "PROXMOX_ISO_STORAGE":  px.get("iso_storage",  default_px["iso_storage"]),
        }

    # Find deploy script
    deploy_sh = None
    for p in ["/usr/local/sbin/debz-deploy-sh",
              "/root/debz/deploy.sh",
              "/opt/debz/deploy.sh"]:
        if Path(p).exists():
            deploy_sh = p
            break
    if not deploy_sh:
        await websocket.send(json.dumps({"type": "error",
            "msg": "deploy script not found", "target": "cluster-deploy"}))
        return

    # Build combined env: default proxmox + per-node JSON map for multi-target
    env = {**os.environ}
    env.update(_env_for_node("__default__"))
    if node_targets:
        env["DEBZ_NODE_TARGETS"] = json.dumps(node_targets)
        # Serialize per-node credentials so deploy.sh can source them
        resolved = {}
        for node, cid in node_targets.items():
            resolved[node] = _env_for_node(node)
        env["DEBZ_NODE_CREDS"] = json.dumps(resolved)

    await _stream_proc(websocket, [deploy_sh, cmd_type], env=env, target="cluster-deploy")

async def _wg_planes_list(websocket):
    """Return all WireGuard interfaces: fixed defaults + user-defined."""
    DEFAULTS = [
        {"iface": "wg0", "subnet": "10.77.0.0/16", "port": 51820, "role": "Enrollment",  "fixed": True},
        {"iface": "wg1", "subnet": "10.78.0.0/16", "port": 51821, "role": "Management",  "fixed": True},
        {"iface": "wg2", "subnet": "10.79.0.0/16", "port": 51822, "role": "Kubernetes",  "fixed": True},
        {"iface": "wg3", "subnet": "10.80.0.0/16", "port": 51823, "role": "Storage",     "fixed": True},
    ]
    planes = list(DEFAULTS)
    # Scan for user-defined planes wg4+
    wg_dir = Path("/etc/wireguard")
    idx = 4
    while True:
        iface = f"wg{idx}"
        conf = wg_dir / f"{iface}.conf"
        if not conf.exists():
            break
        label, subnet, port = iface, "", 0
        try:
            text = conf.read_text()
            for line in text.splitlines():
                if line.startswith("# label="):
                    label = line.split("=", 1)[1].strip()
                if "Address" in line:
                    subnet = line.split("=", 1)[1].strip()
                if "ListenPort" in line:
                    port = int(line.split("=", 1)[1].strip())
        except Exception:
            pass
        planes.append({"iface": iface, "subnet": subnet, "port": port,
                        "role": label, "fixed": False})
        idx += 1
    await websocket.send(json.dumps({"type": "wg_planes", "planes": planes}))

async def _wg_plane_create(websocket, msg):
    label  = msg.get("label", "custom").replace(" ", "-")[:32]
    subnet = msg.get("subnet", "")
    port   = int(msg.get("port", 0))
    if not subnet or not port:
        await websocket.send(json.dumps({"type": "error", "msg": "subnet and port required"}))
        return
    # Find next free interface index
    idx = 4
    while Path(f"/etc/wireguard/wg{idx}.conf").exists():
        idx += 1
    iface = f"wg{idx}"
    try:
        privkey = subprocess.check_output(["wg", "genkey"], text=True).strip()
        pubkey  = subprocess.check_output(["wg", "pubkey"], input=privkey, text=True).strip()
        conf = f"""# label={label}
[Interface]
Address = {subnet.split('/')[0].rsplit('.', 1)[0]}.1/{subnet.split('/')[1]}
ListenPort = {port}
PrivateKey = {privkey}
"""
        Path(f"/etc/wireguard/{iface}.conf").write_text(conf)
        Path(f"/etc/wireguard/{iface}.conf").chmod(0o600)
        subprocess.check_call(["systemctl", "enable", "--now", f"wg-quick@{iface}"],
                               stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        await websocket.send(json.dumps({"type": "wg_plane_created",
            "iface": iface, "pubkey": pubkey, "label": label}))
        await _wg_planes_list(websocket)
    except Exception as e:
        await websocket.send(json.dumps({"type": "error", "msg": f"plane create failed: {e}"}))

async def _wg_plane_delete(websocket, msg):
    iface = msg.get("iface", "")
    if not re.match(r'^wg[4-9][0-9]*$', iface):
        await websocket.send(json.dumps({"type": "error", "msg": "can only delete user-defined planes (wg4+)"}))
        return
    try:
        subprocess.call(["systemctl", "disable", "--now", f"wg-quick@{iface}"],
                        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        conf = Path(f"/etc/wireguard/{iface}.conf")
        if conf.exists():
            conf.unlink()
        await websocket.send(json.dumps({"type": "wg_plane_deleted", "iface": iface}))
        await _wg_planes_list(websocket)
    except Exception as e:
        await websocket.send(json.dumps({"type": "error", "msg": f"plane delete failed: {e}"}))

async def _run_audit(websocket):
    """Run debz-audit --json, stream the log, then push the parsed results."""
    audit_bin = "/usr/local/sbin/debz-audit"
    if not os.path.exists(audit_bin):
        await websocket.send(json.dumps({"type": "error", "msg": "debz-audit not found"}))
        return
    await websocket.send(json.dumps({"type": "audit_started"}))
    # Run with --json so we can parse final results, but also capture the log
    try:
        proc = await asyncio.create_subprocess_exec(
            audit_bin, "--json",
            stdout=asyncio.subprocess.PIPE,
            stderr=asyncio.subprocess.STDOUT,
        )
        stdout, _ = await proc.communicate()
        output = stdout.decode(errors="replace").strip()
        # Try to parse JSON results
        try:
            results = json.loads(output)
        except json.JSONDecodeError:
            results = []
        pass_count = sum(1 for r in results if r.get("status") == "PASS")
        fail_count = sum(1 for r in results if r.get("status") == "FAIL")
        skip_count = sum(1 for r in results if r.get("status") == "SKIP")
        await websocket.send(json.dumps({
            "type": "audit_done",
            "results": results,
            "summary": {"pass": pass_count, "fail": fail_count, "skip": skip_count},
            "rc": proc.returncode,
        }))
    except Exception as exc:
        await websocket.send(json.dumps({"type": "error", "msg": str(exc)}))


async def _vm_clone(websocket, msg):
    """Clone a VM from its golden image and stamp a new identity."""
    src_vm   = msg.get("vm", "")
    new_name = msg.get("new_name", "")
    if not re.match(r'^[a-zA-Z0-9_\-]+$', src_vm):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid vm name"}))
        return
    if not new_name:
        import time as _time
        new_name = f"{src_vm}-clone-{int(_time.time()) % 100000}"
    await websocket.send(json.dumps({"type": "log_line", "line": f"[clone] Cloning {src_vm} → {new_name}", "target": "vm-log"}))
    golden_dir = Path("/var/lib/debz/golden")
    image_path = golden_dir / f"{src_vm}.qcow2"
    if not image_path.exists():
        # Fall back: look for any golden matching the vm's role pattern
        await websocket.send(json.dumps({"type": "log_line", "line": f"[clone] No golden image for {src_vm} — using live disk clone via virsh", "target": "vm-log"}))
        cmd = ["virt-clone", "--original", src_vm, "--name", new_name, "--auto-clone"]
    else:
        clone_path = golden_dir / f"{new_name}.qcow2"
        try:
            subprocess.check_call(
                ["qemu-img", "create", "-f", "qcow2", "-b", str(image_path), "-F", "qcow2", str(clone_path)],
                stderr=subprocess.DEVNULL
            )
        except Exception as e:
            await websocket.send(json.dumps({"type": "error", "msg": f"qemu-img clone failed: {e}"}))
            return
        cmd = ["debz-stamp-identity", "--hostname", new_name, "--image", str(clone_path), "--start"]
    await _stream_proc(websocket, cmd, target="vm-log")
    db_log_event("vm_clone", src_vm, f"Cloned {src_vm} → {new_name}")
    await websocket.send(json.dumps({"type": "exec_done", "rc": 0, "target": "vm-log"}))

async def _vm_replace(websocket, msg):
    """Replace a VM: clone it, then destroy the original."""
    vm = msg.get("vm", "")
    if not re.match(r'^[a-zA-Z0-9_\-]+$', vm):
        await websocket.send(json.dumps({"type": "error", "msg": "invalid vm name"}))
        return
    import time as _time
    new_name = f"{vm}-new-{int(_time.time()) % 100000}"
    await websocket.send(json.dumps({"type": "log_line", "line": f"[replace] Starting replace of {vm}", "target": "vm-log"}))
    # Step 1: clone
    await _vm_clone(websocket, {"vm": vm, "new_name": new_name})
    # Step 2: destroy original
    await websocket.send(json.dumps({"type": "log_line", "line": f"[replace] Destroying original {vm}", "target": "vm-log"}))
    try:
        subprocess.call(["virsh", "destroy", vm], stderr=subprocess.DEVNULL)
        subprocess.call(["virsh", "undefine", "--nvram", vm], stderr=subprocess.DEVNULL)
    except Exception as e:
        await websocket.send(json.dumps({"type": "log_line", "line": f"[replace] WARNING: destroy failed: {e}", "target": "vm-log"}))
    db_log_event("vm_replace", vm, f"Replaced {vm} with {new_name}")
    await websocket.send(json.dumps({"type": "log_line", "line": f"[replace] Done. New VM: {new_name}", "target": "vm-log"}))

async def _service_deploy(websocket, msg):
    """Deploy a service to target nodes via Salt highstate.
    Generates a Salt state from the service definition and pushes it."""
    svc_id = msg.get("id", "")
    svc    = db_load_service(svc_id) if svc_id else msg.get("service")
    if not svc:
        await websocket.send(json.dumps({"type": "error", "msg": "service not found"}))
        return

    name     = svc.get("name", "unknown")
    dataset  = svc.get("dataset") or f"rpool/services/{name}"
    image    = svc.get("image", "")
    runtime  = svc.get("runtime", "systemd")
    config   = svc.get("config", {})
    targets  = svc.get("node_targets", [])
    salt_tgt = " ".join(targets) if targets else "*"

    await websocket.send(json.dumps({
        "type": "log_line", "line": f"[deploy] Deploying service: {name}", "target": "svc-log"
    }))

    # Generate Salt state YAML
    salt_state = _generate_salt_state(name, dataset, image, runtime, config)

    # Write state to /srv/salt/debz/services/<name>.sls
    state_dir  = Path(f"/srv/salt/debz/services")
    state_file = state_dir / f"{name}.sls"
    try:
        state_dir.mkdir(parents=True, exist_ok=True)
        state_file.write_text(salt_state)
        await websocket.send(json.dumps({
            "type": "log_line", "line": f"[deploy] State written: {state_file}", "target": "svc-log"
        }))
    except Exception as e:
        await websocket.send(json.dumps({
            "type": "log_line", "line": f"[deploy] WARNING: could not write state: {e}", "target": "svc-log"
        }))

    # Update DB: mark as deploying
    if svc_id:
        db_update_service_status(svc_id, "deploying")

    # Push via Salt
    cmd = ["salt", salt_tgt, "state.apply", f"debz.services.{name}",
           "--timeout=60", "--out=yaml"]
    await _stream_proc(websocket, cmd, target="svc-log")

    if svc_id:
        db_update_service_status(svc_id, "running")
    db_log_event("service_deploy", svc_id or name, f"Service deployed: {name} → {salt_tgt}")
    await websocket.send(json.dumps({"type": "exec_done", "rc": 0, "target": "svc-log"}))

def _generate_salt_state(name, dataset, image, runtime, config):
    """Generate a Salt state YAML for a ZFS-backed service."""
    mountpoint = f"/srv/services/{name}"
    env_lines  = "\n".join(
        f"    - {k}={v}" for k, v in (config.get("env") or {}).items()
    )
    ports      = config.get("ports", [])
    port_lines = "\n".join(f"    - {p}" for p in ports) if ports else ""

    if runtime == "nspawn":
        svc_block = f"""
{name}-nspawn:
  nspawn.running:
    - name: {name}
    - root: {mountpoint}
    - require:
      - zfs: {dataset}
"""
    elif runtime == "podman":
        svc_block = f"""
{name}-container:
  cmd.run:
    - name: >-
        podman run -d --name {name}
        --restart=always
        -v {mountpoint}:/data
        {chr(10).join('        -e ' + l.strip('- ') for l in env_lines.splitlines()) if env_lines else ''}
        {chr(10).join('        -p ' + l.strip('- ') for l in port_lines.splitlines()) if port_lines else ''}
        {image or 'debian:trixie'}
    - unless: podman inspect {name}
    - require:
      - zfs: {dataset}
"""
    else:  # systemd / bare
        svc_block = f"""
{name}-service:
  service.running:
    - name: {name}
    - enable: True
    - require:
      - zfs: {dataset}
"""

    return f"""# Auto-generated by debz-webui — do not edit manually
# Service: {name}  Runtime: {runtime}

# 1. Ensure ZFS dataset exists
{dataset}:
  zfs.filesystem_present:
    - properties:
        compression: lz4
        mountpoint: {mountpoint}
        com.sun:auto-snapshot: 'true'

# 2. Ensure mountpoint directory exists
{mountpoint}:
  file.directory:
    - makedirs: True
    - require:
      - zfs: {dataset}
{svc_block}
"""

# ── HTTP handler ───────────────────────────────────────────────────────────────

class WebUIHandler(SimpleHTTPRequestHandler):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, directory=str(WEBUI_DIR), **kwargs)

    def log_message(self, fmt, *args):
        pass  # silence access log

    def do_GET(self):
        if self.path == "/" or self.path == "":
            self.path = "/index.html"
        super().do_GET()

# ── Main ───────────────────────────────────────────────────────────────────────

def _get_ssl_context():
    """Try to generate a per-boot TLS cert and return an SSLContext.
    Returns None if the CA is not present (falls back to plain HTTP)."""
    try:
        result = subprocess.check_output(
            ["/usr/local/sbin/debz-tls-cert"], text=True
        ).strip()
        key_path, crt_path = result.split()
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        ctx.load_cert_chain(certfile=crt_path, keyfile=key_path)
        LOG.info("TLS cert loaded: %s", crt_path)
        return ctx
    except Exception as e:
        LOG.warning("TLS setup failed, falling back to plain HTTP: %s", e)
        return None

async def main_async(args):
    import http
    import mimetypes
    from websockets.http11 import Response as WsResponse
    from websockets.datastructures import Headers as WsHeaders

    db_init()
    ssl_ctx = _get_ssl_context()
    scheme    = "https" if ssl_ctx else "http"

    async def process_request(connection, request):
        """Serve static HTTP requests inline; return None to allow WS upgrade."""
        if request.headers.get("Upgrade", "").lower() == "websocket":
            return None  # hand off to ws_handler
        url_path = request.path.split("?")[0] or "/"
        if url_path == "/":
            url_path = "/index.html"
        file_path = WEBUI_DIR / url_path.lstrip("/")
        # Prevent path traversal
        try:
            file_path.resolve().relative_to(WEBUI_DIR.resolve())
        except ValueError:
            return WsResponse(403, "Forbidden", WsHeaders([]), b"Forbidden\n")
        if not file_path.exists() or not file_path.is_file():
            return WsResponse(404, "Not Found", WsHeaders([]), b"Not Found\n")
        ctype, _ = mimetypes.guess_type(str(file_path))
        body = file_path.read_bytes()
        headers = WsHeaders([
            ("Content-Type", ctype or "application/octet-stream"),
            ("Content-Length", str(len(body))),
            ("Cache-Control", "no-cache"),
        ])
        return WsResponse(200, "OK", headers, body)

    # Single port for both HTTP (static files) and WebSocket
    ws_server = await websockets.serve(
        ws_handler, args.bind, args.port,
        ping_interval=20, ping_timeout=10,
        ssl=ssl_ctx,
        process_request=process_request,
    )
    LOG.info("debz Web UI on %s://%s:%d (HTTP + WebSocket)", scheme, args.bind, args.port)

    url = f"{scheme}://localhost:{args.port}"
    LOG.info("debz Web UI ready: %s", url)

    if not args.no_browser:
        for cmd in ["xdg-open", "firefox-esr", "chromium"]:
            try:
                subprocess.Popen([cmd, url],
                                  stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                break
            except FileNotFoundError:
                continue

    await ws_server.wait_closed()

def main():
    parser = argparse.ArgumentParser(description="debz Web UI")
    parser.add_argument("--port",       type=int, default=8080,  help="HTTP + WebSocket port (default 8080)")
    parser.add_argument("--bind",       default="0.0.0.0",       help="Bind address (default 0.0.0.0)")
    parser.add_argument("--no-browser", action="store_true",     help="Don't open browser")
    args = parser.parse_args()

    try:
        asyncio.run(main_async(args))
    except KeyboardInterrupt:
        LOG.info("Shutting down")

if __name__ == "__main__":
    main()
