def db_export_all():
    """Export entire DB as a JSON dict (for seed disk / live→master handoff)."""
    con = _db_connect()
    export = {}
    for table in ("templates", "nodes", "clusters", "vms", "services", "events"):
        try:
            rows = con.execute(f"SELECT * FROM {table}").fetchall()
            export[table] = [dict(r) for r in rows]
        except Exception:
            export[table] = []
    con.close()
    return export

def db_import_all(data, merge=True):
    """Import a DB export dict. merge=True skips rows with existing PKs."""
    con = _db_connect()
    counts = {}
    for table, rows in data.items():
        if table == "events":
            continue  # events are append-only, skip import
        n = 0
        for row in rows:
            cols = list(row.keys())
            placeholders = ",".join(["?"] * len(cols))
            vals = [row[c] for c in cols]
            conflict = "OR IGNORE" if merge else "OR REPLACE"
            try:
                con.execute(
                    f"INSERT {conflict} INTO {table} ({','.join(cols)}) VALUES ({placeholders})",
                    vals
                )
                n += 1
            except Exception:
                pass
        counts[table] = n
    con.commit()
    con.close()
    return counts

def is_live_mode():
    """Return True if running on the live ISO (not installed system)."""
    try:
        cmdline = Path("/proc/cmdline").read_text()
        if "boot=live" in cmdline:
            return True
    except Exception:
        pass
    node_env = Path("/etc/debz/node.env")
    return not node_env.exists()

def get_node_env():
    """Return dict of key=value pairs from /etc/debz/node.env, or {} if absent."""
    env = {}
    try:
        for line in Path("/etc/debz/node.env").read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                k, _, v = line.partition("=")
                env[k.strip()] = v.strip()
    except Exception:
        pass
    return env

# ── Disk detection ─────────────────────────────────────────────────────────────

def get_disks():
    """Return list of usable block devices."""
    try:
        out = subprocess.check_output(
            ["lsblk", "-J", "-o", "NAME,SIZE,MODEL,TYPE,RM,MOUNTPOINT"],
            text=True
        )
        data = json.loads(out)
        disks = []
        for d in data.get("blockdevices", []):
            if d.get("type") == "disk":
                disks.append({
                    "name":       f'/dev/{d["name"]}',
                    "size":       d.get("size", "?"),
                    "model":      d.get("model", "").strip(),
                    "removable":  d.get("rm", False),
                    "mountpoint": d.get("mountpoint"),
                })
        return disks
    except Exception as e:
        LOG.error("lsblk failed: %s", e)
        return []

def get_system_info():
    """Return basic system info dict."""
    info = {}
    try:
        info["hostname"] = open("/etc/hostname").read().strip()
    except Exception:
        info["hostname"] = "unknown"
    try:
        mem = subprocess.check_output(["free", "-h"], text=True).splitlines()[1].split()
        info["memory_total"] = mem[1]
        info["memory_free"]  = mem[3]
    except Exception:
        info["memory_total"] = "?"
        info["memory_free"]  = "?"
    try:
        info["cpus"] = subprocess.check_output(["nproc"], text=True).strip()
    except Exception:
        info["cpus"] = "?"
    try:
        uptime_s = subprocess.check_output(["uptime", "-p"], text=True).strip()
        info["uptime"] = uptime_s
    except Exception:
        pass
    try:
        with open("/etc/debz/install-manifest.env") as f:
            for line in f:
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    k, v = line.split("=", 1)
                    info[k.lower()] = v
    except Exception:
        pass
    info["edition"] = EDITION
    # Live mode: no DEBZ_INSTALLED=1 in manifest
    info["live_mode"] = True
    try:
        with open("/etc/debz/install-manifest.env") as f:
            if "DEBZ_INSTALLED=1" in f.read():
                info["live_mode"] = False
    except Exception:
        pass
    # Grains: node_index, wg1_ip
    try:
        grains_path = "/etc/salt/grains"
        if os.path.exists(grains_path) and yaml is not None:
            with open(grains_path) as f:
                grains = yaml.safe_load(f) or {}
            info["node_index"] = grains.get("node_index", "")
            info["wg1_ip"]     = grains.get("wg1_ip", "")
    except Exception:
        pass
    # Quick WG up/down status for dashboard mini-table
    info["wg"] = {}
    for n, net in [(0, "10.77"), (1, "10.78"), (2, "10.79"), (3, "10.80")]:
        iface = f"wg{n}"
        entry = {"up": False, "ip": ""}
        try:
            out = subprocess.check_output(
                ["ip", "-o", "addr", "show", iface],
                text=True, stderr=subprocess.DEVNULL
            )
            m = re.search(r"inet (\S+)", out)
            if m:
                entry["ip"] = m.group(1).split("/")[0]
                entry["up"] = True
        except Exception:
            pass
        info["wg"][iface] = entry
    return info


def get_wg_status():
    """Return detailed WireGuard status for all four planes."""
    data = {}
    for n in range(4):
        iface = f"wg{n}"
        entry = {"up": False, "ip": "", "peers": 0, "peer_list": []}
        try:
            out = subprocess.check_output(
                ["ip", "-o", "addr", "show", iface],
                text=True, stderr=subprocess.DEVNULL
            )
            m = re.search(r"inet (\S+)", out)
            if m:
                entry["ip"]  = m.group(1).split("/")[0]
                entry["up"]  = True
        except Exception:
            pass
        try:
            wg_out = subprocess.check_output(
                ["wg", "show", iface, "dump"],
                text=True, stderr=subprocess.DEVNULL
            )
            peers = []
            for line in wg_out.strip().splitlines()[1:]:  # skip own pubkey line
                parts = line.split("\t")
                if len(parts) >= 5:
                    pub   = parts[0]
                    ep    = parts[2] if parts[2] != "(none)" else "—"
                    aips  = parts[3]
                    hs    = parts[4]
                    rx_tx = f"{parts[5]} / {parts[6]}" if len(parts) > 6 else "—"
                    peers.append({
                        "pubkey":       pub,
                        "pubkey_short": pub[:12] + "…",
                        "endpoint":     ep,
                        "allowed_ips":  aips,
                        "last_handshake": _fmt_handshake(hs),
                        "transfer":     rx_tx,
                    })
            entry["peers"]     = len(peers)
            entry["peer_list"] = peers
        except Exception:
            pass
        data[iface] = entry
    return data


def get_network_interfaces():
    """Return list of network interfaces with addresses."""
    ifaces = []
    try:
        out = subprocess.check_output(
            ["ip", "-o", "addr", "show"],
            text=True, stderr=subprocess.DEVNULL
        )
        seen = {}
        for line in out.splitlines():
            parts = line.split()
            if len(parts) < 4:
                continue
            name  = parts[1]
            family = parts[2]
            addr  = parts[3]
            if family not in ("inet", "inet6"):
                continue
            if name not in seen:
                seen[name] = {"name": name, "addresses": [], "state": "DOWN", "mtu": ""}
            seen[name]["addresses"].append(addr)
        # Get state and MTU
        link_out = subprocess.check_output(
            ["ip", "-o", "link", "show"],
            text=True, stderr=subprocess.DEVNULL
        )
        for line in link_out.splitlines():
            m_name = re.match(r"\d+:\s+(\S+):", line)
            if not m_name:
                continue
            name = m_name.group(1).rstrip("@eth0").split("@")[0]
            if name not in seen:
                seen[name] = {"name": name, "addresses": [], "state": "DOWN", "mtu": ""}
            seen[name]["state"] = "UP" if "UP" in line else "DOWN"
            m_mtu = re.search(r"mtu (\d+)", line)
            if m_mtu:
                seen[name]["mtu"] = m_mtu.group(1)
        ifaces = [v for k, v in sorted(seen.items()) if k != "lo"]
    except Exception as e:
        LOG.warning("network info failed: %s", e)
    return ifaces


def get_golden_status():
    """Return exists/size for each golden image template."""
    golden_dir = Path("/var/lib/debz/golden")
    status = {}
    for tmpl in ("master", "kvm", "storage", "vdi"):
        path = golden_dir / f"golden-{tmpl}.qcow2"
        if path.exists():
            size_bytes = path.stat().st_size
            size_hr = _human_size(size_bytes)
            status[tmpl] = {"exists": True, "size": size_hr, "path": str(path)}
        else:
            status[tmpl] = {"exists": False}
    return status


def _fmt_handshake(ts_str):
    """Convert epoch timestamp to human-readable."""
    try:
        ts = int(ts_str)
        if ts == 0:
            return "never"
        delta = int(time.time()) - ts
        if delta < 120:
            return f"{delta}s ago"
        elif delta < 7200:
            return f"{delta // 60}m ago"
        else:
            return f"{delta // 3600}h ago"
    except Exception:
        return ts_str


def _human_size(n):
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if n < 1024:
            return f"{n:.1f} {unit}"
        n /= 1024
    return f"{n:.1f} PB"

def _load_credentials():
    try:
        return json.loads(CREDENTIALS_PATH.read_text())
    except Exception:
        return {"proxmox": [], "aws": {}, "azure": {}, "gcp": {}, "ssh": []}

def _save_credentials(creds):
    CREDENTIALS_PATH.parent.mkdir(parents=True, exist_ok=True)
    CREDENTIALS_PATH.write_text(json.dumps(creds, indent=2))
    os.chmod(CREDENTIALS_PATH, 0o600)

