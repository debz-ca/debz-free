#!/usr/bin/env python3
"""
debz-reconcile — Infrastructure reconciliation loop.
Runs on the master node. Compares desired state (state.db) against
actual state (Salt mine + virsh). Logs drift events.
"""
import argparse
import datetime
import json
import logging
import sqlite3
import subprocess
import sys
import time
import uuid
from pathlib import Path

DB_PATH = Path("/var/lib/debz/state.db")
LOG = logging.getLogger("debz-reconcile")
logging.basicConfig(
    level=logging.INFO,
    format="[%(asctime)s] [reconcile] %(message)s",
    datefmt="%Y-%m-%dT%H:%M:%S",
)

def _now():
    return datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")

def _db():
    if not DB_PATH.exists():
        return None
    con = sqlite3.connect(DB_PATH)
    con.row_factory = sqlite3.Row
    return con

def db_log_event(con, type_, subject, message, data=None):
    con.execute(
        "INSERT INTO events (ts,type,subject,message,data) VALUES (?,?,?,?,?)",
        (_now(), type_, subject, message, json.dumps(data or {}))
    )
    con.commit()

def get_salt_grains():
    """Query all minion grains. Returns dict of hostname -> grains."""
    try:
        out = subprocess.check_output(
            ["salt", "*", "grains.items", "--out=json", "--timeout=10"],
            text=True, stderr=subprocess.DEVNULL, timeout=30
        )
        return json.loads(out)
    except Exception as e:
        LOG.warning("salt grains query failed: %s", e)
        return {}

def get_virsh_vms():
    """Get list of VMs on this host. Returns list of dicts."""
    vms = []
    try:
        out = subprocess.check_output(
            ["virsh", "list", "--all", "--name"],
            text=True, stderr=subprocess.DEVNULL
        )
        for name in out.strip().splitlines():
            name = name.strip()
            if not name:
                continue
            state = "unknown"
            try:
                state = subprocess.check_output(
                    ["virsh", "domstate", name],
                    text=True, stderr=subprocess.DEVNULL
                ).strip()
            except Exception:
                pass
            vms.append({"name": name, "state": state})
    except Exception:
        pass
    return vms

ANSIBLE_INVENTORY_PATH = Path("/etc/debz/inventory")
ANSIBLE_DIR            = Path("/srv/ansible")


def _write_ansible_inventory(con):
    """Write /etc/debz/inventory in INI format from live state.db node records.
    Groups: cluster_manager, kvm, proxmox, storage, vdi, worker, etcd, all.
    Also writes /srv/ansible/inventory/hosts.ini if that path exists.
    """
    try:
        rows = con.execute(
            "SELECT hostname, role, ip_mgmt, ip_wg1, facts FROM nodes WHERE status='online'"
        ).fetchall()
        if not rows:
            return

        groups: dict[str, list] = {}
        host_vars: dict[str, dict] = {}

        for r in rows:
            hn   = r["hostname"]
            role = (r["role"] or "unknown").replace("-", "_")
            mgmt = r["ip_mgmt"] or ""
            wg1  = r["ip_wg1"]  or ""
            try:
                facts = json.loads(r["facts"] or "{}")
            except Exception:
                facts = {}

            groups.setdefault(role, []).append(hn)
            groups.setdefault("all_nodes", []).append(hn)

            hv: dict = {}
            if mgmt:
                hv["ansible_host"] = wg1 if wg1 else mgmt
            if wg1:
                hv["wg1_ip"]   = wg1
            if mgmt:
                hv["mgmt_ip"]  = mgmt
            hv["debz_role"]    = role
            # Proxmox extra vars from grains
            for k in ("proxmox_api_url", "proxmox_token_id"):
                if facts.get(k):
                    hv[k] = facts[k]
            host_vars[hn] = hv

        lines = [
            "# Auto-generated by debz-reconcile — do not edit by hand",
            "# Last updated: " + _now(),
            "",
        ]
        for group, hosts in sorted(groups.items()):
            if group == "all_nodes":
                continue
            lines.append(f"[{group}]")
            for h in sorted(set(hosts)):
                hv = host_vars.get(h, {})
                extras = " ".join(f"{k}={v}" for k, v in sorted(hv.items()))
                lines.append(f"{h} {extras}".rstrip())
            lines.append("")

        # [all:vars] — shared defaults
        lines += [
            "[all:vars]",
            "ansible_user=ansible",
            f"ansible_ssh_private_key_file=/home/ansible/.ssh/id_ed25519",
            "ansible_ssh_common_args='-o StrictHostKeyChecking=accept-new'",
            "",
        ]

        content = "\n".join(lines) + "\n"
        ANSIBLE_INVENTORY_PATH.parent.mkdir(parents=True, exist_ok=True)
        ANSIBLE_INVENTORY_PATH.write_text(content)

        # Mirror to /srv/ansible/inventory/hosts.ini if that tree exists
        alt = ANSIBLE_DIR / "inventory" / "hosts.ini"
        if alt.parent.exists():
            alt.write_text(content)

        LOG.info("Ansible inventory written: %s (%d nodes)",
                 ANSIBLE_INVENTORY_PATH, len(host_vars))
    except Exception as e:
        LOG.warning("Ansible inventory generation failed: %s", e)


def reconcile_tick():
    con = _db()
    if not con:
        LOG.warning("State DB not found at %s — skipping tick", DB_PATH)
        return

    LOG.info("Reconcile tick starting")

    # ── 1. Update node inventory from Salt grains ─────────────────────────────
    grains_by_host = get_salt_grains()
    now = _now()

    for hostname, grains in grains_by_host.items():
        role      = grains.get("debz_role", "unknown")
        ip_mgmt   = grains.get("debz_ip_mgmt", "")
        ip_wg0    = grains.get("debz_wg0_ip", "")
        ip_wg1    = grains.get("debz_wg1_ip", "")
        ip_wg2    = grains.get("debz_wg2_ip", "")
        ip_wg3    = grains.get("debz_wg3_ip", "")
        wg_pubkey = grains.get("debz_wg_pubkey", "")
        cluster   = grains.get("debz_cluster", "")

        row = con.execute("SELECT id,status FROM nodes WHERE hostname=?", (hostname,)).fetchone()
        if row:
            was_offline = row["status"] != "online"
            con.execute(
                "UPDATE nodes SET role=?,ip_mgmt=?,ip_wg0=?,ip_wg1=?,ip_wg2=?,ip_wg3=?,"
                "wg_pubkey=?,cluster_id=?,status='online',last_seen=?,facts=? WHERE hostname=?",
                (role, ip_mgmt, ip_wg0, ip_wg1, ip_wg2, ip_wg3,
                 wg_pubkey, cluster, now, json.dumps(grains), hostname)
            )
            if was_offline:
                db_log_event(con, "node_recovered", row["id"],
                             f"Node back online: {hostname}")
        else:
            node_id = str(uuid.uuid4())
            con.execute(
                "INSERT INTO nodes (id,hostname,role,ip_mgmt,ip_wg0,ip_wg1,ip_wg2,ip_wg3,"
                "wg_pubkey,cluster_id,status,last_seen,facts,created_at) VALUES "
                "(?,?,?,?,?,?,?,?,?,?,?,?,?,?)",
                (node_id, hostname, role, ip_mgmt, ip_wg0, ip_wg1, ip_wg2, ip_wg3,
                 wg_pubkey, cluster, "online", now, json.dumps(grains), now)
            )
            db_log_event(con, "node_joined", node_id, f"New node discovered: {hostname}")
            LOG.info("New node: %s (role=%s)", hostname, role)

    con.commit()

    # ── 2. Mark nodes not seen in Salt as offline ─────────────────────────────
    known = set(grains_by_host.keys())
    stale_cutoff = 120  # seconds — mark offline if not seen in 2 min
    all_nodes = con.execute("SELECT id,hostname,status,last_seen FROM nodes").fetchall()
    for n in all_nodes:
        if n["hostname"] in known:
            continue
        if n["status"] == "online":
            try:
                last = datetime.datetime.strptime(n["last_seen"], "%Y-%m-%dT%H:%M:%SZ")
                age  = (datetime.datetime.utcnow() - last).total_seconds()
                if age > stale_cutoff:
                    con.execute("UPDATE nodes SET status='offline' WHERE id=?", (n["id"],))
                    db_log_event(con, "node_offline", n["id"],
                                 f"Node went offline: {n['hostname']}")
                    LOG.warning("Node offline: %s (last seen %ds ago)", n["hostname"], age)
            except Exception:
                pass

    con.commit()

    # ── 3. Check desired clusters vs actual nodes ─────────────────────────────
    clusters = con.execute("SELECT * FROM clusters WHERE status != 'designing'").fetchall()
    for cluster in clusters:
        try:
            desired = json.loads(cluster["data"])
        except Exception:
            continue
        desired_count = sum(g.get("count", 1) for g in desired.get("groups", []))
        actual_count  = len([
            n for n in all_nodes
            if n["hostname"] in known and
               con.execute("SELECT cluster_id FROM nodes WHERE hostname=?",
                           (n["hostname"],)).fetchone() and
               (con.execute("SELECT cluster_id FROM nodes WHERE hostname=?",
                            (n["hostname"],)).fetchone()["cluster_id"] == cluster["id"])
        ])
        if desired_count > 0 and actual_count < desired_count:
            LOG.warning("Cluster %s: desired %d nodes, actual %d",
                        cluster["name"], desired_count, actual_count)
            db_log_event(con, "cluster_drift", cluster["id"],
                         f"Cluster {cluster['name']}: desired {desired_count} nodes, "
                         f"actual {actual_count}",
                         {"desired": desired_count, "actual": actual_count})

    con.commit()

    # ── 4. Generate Ansible inventory from state.db ────────────────────────
    _write_ansible_inventory(con)

    con.close()
    LOG.info("Reconcile tick complete — %d salt nodes, %d clusters checked",
             len(grains_by_host), len(clusters))

def main():
    parser = argparse.ArgumentParser(description="debz reconciliation loop")
    parser.add_argument("--interval", type=int, default=30, help="Seconds between ticks")
    parser.add_argument("--once",     action="store_true",   help="Run once and exit")
    args = parser.parse_args()

    LOG.info("debz-reconcile starting (interval=%ds)", args.interval)

    if args.once:
        reconcile_tick()
        return

    while True:
        try:
            reconcile_tick()
        except Exception as e:
            LOG.exception("Reconcile tick failed: %s", e)
        time.sleep(args.interval)

if __name__ == "__main__":
    main()
