#!/usr/bin/env python3
"""
debz-dns-api — DNS registration API for MASTER nodes.

Listens on :8081 and accepts POST /api/dns/register from worker nodes.
Writes A records into the cluster.debz PowerDNS zone via pdnsutil, then
signals pdns_control to reload the zone.

Expected JSON body:
  {
    "hostname": "kvm-03",
    "records": {
      "node": "10.78.1.3",   <- wg1 management plane (primary A record)
      "wg0":  "10.77.1.3",
      "wg1":  "10.78.1.3",
      "wg2":  "10.79.1.3",
      "wg3":  "10.80.1.3"
    }
  }

Records written (TTL 300):
  <hostname>.node.cluster.debz  A  <records.node>
  <hostname>.wg0.cluster.debz   A  <records.wg0>
  <hostname>.wg1.cluster.debz   A  <records.wg1>
  <hostname>.wg2.cluster.debz   A  <records.wg2>
  <hostname>.wg3.cluster.debz   A  <records.wg3>

Usage:
  debz-dns-api [--bind 0.0.0.0] [--port 8081] [--zone cluster.debz]
               [--ttl 300] [--log /var/log/debz/dns-api.log]

Managed by debz-dns-api.service (MASTER role only).
"""

import argparse
import ipaddress
import json
import logging
import os
import re
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

# ---------------------------------------------------------------------------
# Mutable config — populated by main() before the server starts
# ---------------------------------------------------------------------------

CFG = {
    "zone":  os.environ.get("DEBZ_DNS_ZONE",  "cluster.debz"),
    "ttl":   int(os.environ.get("DEBZ_DNS_TTL", "300")),
    "log":   os.environ.get("DEBZ_DNS_LOG",   "/var/log/debz/dns-api.log"),
    "bind":  os.environ.get("DEBZ_DNS_BIND",  "0.0.0.0"),
    "port":  int(os.environ.get("DEBZ_DNS_PORT", "8081")),
}

# Record types accepted from the payload -> DNS label suffix
RECORD_TYPES = {"node": "node", "wg0": "wg0", "wg1": "wg1", "wg2": "wg2", "wg3": "wg3"}

HOSTNAME_RE = re.compile(r'^[a-z0-9]([a-z0-9\-]{0,61}[a-z0-9])?$', re.IGNORECASE)

log = logging.getLogger("debz-dns-api")

# ---------------------------------------------------------------------------
# Logging setup (called after CFG is finalised)
# ---------------------------------------------------------------------------

def _setup_logging(log_path: str) -> None:
    os.makedirs(os.path.dirname(log_path) or ".", exist_ok=True)
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s [dns-api] %(levelname)s %(message)s",
        datefmt="%Y-%m-%dT%H:%M:%S",
        handlers=[
            logging.FileHandler(log_path),
            logging.StreamHandler(sys.stdout),
        ],
    )

# ---------------------------------------------------------------------------
# pdnsutil helpers
# ---------------------------------------------------------------------------

def _pdnsutil(*args: str) -> tuple:
    """Run pdnsutil with the given arguments. Returns (returncode, stdout, stderr)."""
    result = subprocess.run(["pdnsutil"] + list(args), capture_output=True, text=True)
    return result.returncode, result.stdout.strip(), result.stderr.strip()


def _ensure_zone(zone: str) -> None:
    """Create the zone with minimal SOA/NS if it does not already exist."""
    rc, _out, _err = _pdnsutil("list-zone", zone)
    if rc == 0:
        return
    log.info("Zone %s not found — creating it", zone)
    rc, out, err = _pdnsutil("create-zone", zone)
    if rc != 0:
        raise RuntimeError(f"Failed to create zone {zone}: {err or out}")
    _pdnsutil("add-record", zone, "@",   "SOA", "3600",
              f"ns1.{zone}. hostmaster.{zone}. 1 3600 900 604800 300")
    _pdnsutil("add-record", zone, "@",   "NS",  "3600", f"ns1.{zone}.")
    _pdnsutil("add-record", zone, "ns1", "A",   "3600", "10.78.1.1")
    log.info("Created zone %s with SOA/NS defaults", zone)


def _replace_record(zone: str, label: str, ip: str, ttl: int) -> None:
    """Upsert an A record using pdnsutil replace-record (falls back to add-record)."""
    rc, out, err = _pdnsutil("replace-record", zone, label, "A", str(ttl), ip)
    if rc != 0:
        rc2, out2, err2 = _pdnsutil("add-record", zone, label, "A", str(ttl), ip)
        if rc2 != 0:
            raise RuntimeError(
                f"Failed to add/replace {label}.{zone} -> {ip}: {err2 or err or out2 or out}"
            )
    log.info("  %-40s  A  %s  (ttl=%s)", f"{label}.{zone}.", ip, ttl)


def _pdns_reload(zone: str) -> None:
    """Signal pdns_control to reload the zone (non-fatal if pdns is not running)."""
    result = subprocess.run(
        ["pdns_control", "reload", zone], capture_output=True, text=True
    )
    if result.returncode != 0:
        log.warning("pdns_control reload %s: non-zero exit (non-fatal)", zone)
    else:
        log.info("pdns_control reload %s: OK", zone)

# ---------------------------------------------------------------------------
# Request handler
# ---------------------------------------------------------------------------

class DnsApiHandler(BaseHTTPRequestHandler):
    """Minimal HTTP handler — only POST /api/dns/register is implemented."""

    server_version = "debz-dns-api/1.0"

    def log_message(self, fmt, *args):  # silence default access log
        pass

    def _respond(self, code: int, body: dict) -> None:
        payload = json.dumps(body).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def _bad(self, msg: str) -> None:
        log.warning("400 %s  client=%s", msg, self.client_address[0])
        self._respond(400, {"error": msg})

    def do_GET(self):  # health check
        if self.path == "/healthz":
            self._respond(200, {"status": "ok", "zone": CFG["zone"]})
        else:
            self.send_response(404)
            self.end_headers()

    def do_POST(self):
        if self.path != "/api/dns/register":
            self.send_response(404)
            self.end_headers()
            return

        length = int(self.headers.get("Content-Length", 0))
        if length > 65536:
            self._bad("payload too large")
            return
        raw = self.rfile.read(length)

        try:
            data = json.loads(raw)
        except json.JSONDecodeError as exc:
            self._bad(f"invalid JSON: {exc}")
            return

        hostname = data.get("hostname", "").strip().lower()
        if not hostname or not HOSTNAME_RE.match(hostname):
            self._bad(f"invalid or missing hostname: {hostname!r}")
            return

        records = data.get("records", {})
        if not isinstance(records, dict) or not records:
            self._bad("'records' must be a non-empty object")
            return

        validated = {}
        for rtype, label in RECORD_TYPES.items():
            ip = records.get(rtype, "").strip()
            if not ip:
                continue
            try:
                ipaddress.IPv4Address(ip)
            except ValueError:
                self._bad(f"invalid IP for {rtype}: {ip!r}")
                return
            validated[label] = ip

        if not validated:
            self._bad("no valid IP records provided")
            return

        log.info("Register: hostname=%s  records=%s  client=%s",
                 hostname, validated, self.client_address[0])

        zone = CFG["zone"]
        ttl  = CFG["ttl"]
        try:
            _ensure_zone(zone)
            for label, ip in validated.items():
                _replace_record(zone, f"{hostname}.{label}", ip, ttl)
            _pdns_reload(zone)
        except Exception as exc:
            log.error("DNS write failed for %s: %s", hostname, exc)
            self._respond(500, {"error": str(exc)})
            return

        written = {f"{hostname}.{lbl}.{zone}": ip for lbl, ip in validated.items()}
        log.info("Registered %s: %d records", hostname, len(written))
        self._respond(201, {"ok": True, "hostname": hostname, "zone": zone,
                            "records": written})

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    parser = argparse.ArgumentParser(description="debz DNS registration API")
    parser.add_argument("--bind",  default=CFG["bind"],
                        help=f"Bind address (default: {CFG['bind']})")
    parser.add_argument("--port",  type=int, default=CFG["port"],
                        help=f"Listen port (default: {CFG['port']})")
    parser.add_argument("--zone",  default=CFG["zone"],
                        help=f"PowerDNS zone (default: {CFG['zone']})")
    parser.add_argument("--ttl",   type=int, default=CFG["ttl"],
                        help=f"DNS TTL seconds (default: {CFG['ttl']})")
    parser.add_argument("--log",   default=CFG["log"],
                        help=f"Log file (default: {CFG['log']})")
    args = parser.parse_args()

    CFG["zone"] = args.zone
    CFG["ttl"]  = args.ttl
    CFG["bind"] = args.bind
    CFG["port"] = args.port
    CFG["log"]  = args.log

    _setup_logging(CFG["log"])

    log.info("debz-dns-api starting  bind=%s:%d  zone=%s  ttl=%d",
             CFG["bind"], CFG["port"], CFG["zone"], CFG["ttl"])

    server = HTTPServer((CFG["bind"], CFG["port"]), DnsApiHandler)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        log.info("Shutting down")
        server.server_close()


if __name__ == "__main__":
    main()
