#!/usr/bin/env bash
# debz-dns-register — register this node's WireGuard IPs in the cluster DNS.
#
# Posts the node's hostname and all four WireGuard plane IPs to the MASTER
# node's DNS registration API (debz-dns-api on port 8081). The MASTER writes
# the records into the cluster.debz zone served by BIND9/PowerDNS.
#
# After successful registration, every node in the cluster can resolve:
#   <hostname>.node.cluster.debz  →  wg1 (management plane) IP
#   <hostname>.wg0.cluster.debz  →  wg0 IP
#   <hostname>.wg1.cluster.debz  →  wg1 IP
#   <hostname>.wg2.cluster.debz  →  wg2 IP
#   <hostname>.wg3.cluster.debz  →  wg3 IP
#
# Usage:
#   debz-dns-register --hostname <name> \
#                     --wg0-ip <ip> --wg1-ip <ip> --wg2-ip <ip> \
#                     --master-api <url>
#
# Options:
#   --hostname    Node hostname (e.g. kvm-03)
#   --wg0-ip      wg0 enrollment plane IP
#   --wg1-ip      wg1 management plane IP  (used as primary A record)
#   --wg2-ip      wg2 k8s/application plane IP
#   --wg3-ip      wg3 storage replication plane IP
#   --master-api  Base URL of the MASTER DNS API  (default: http://10.77.1.1:8081)
#   --retries     Number of retry attempts on failure  (default: 3)
#   --timeout     HTTP timeout per attempt in seconds  (default: 10)
#
# Exit codes:
#   0  registered successfully
#   1  all attempts failed (caller treats as non-fatal warning)
#
set -euo pipefail

LOG=/var/log/debz/firstboot.log
HOSTNAME_ARG=""
WG0_IP=""
WG1_IP=""
WG2_IP=""
WG3_IP=""
MASTER_API="http://10.77.1.1:8081"
RETRIES=3
TIMEOUT=10

log()  { printf '[%(%F %T)T] [dns-register] %s\n' -1 "$*" | tee -a "${LOG}"; }
die()  { log "FATAL: $*"; exit 1; }
warn() { log "WARNING: $*"; }
ok()   { log "OK: $*"; }

# ── Parse arguments ───────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --hostname)    HOSTNAME_ARG="$2"; shift ;;
    --hostname=*)  HOSTNAME_ARG="${1#--hostname=}" ;;
    --wg0-ip)      WG0_IP="$2";       shift ;;
    --wg0-ip=*)    WG0_IP="${1#--wg0-ip=}" ;;
    --wg1-ip)      WG1_IP="$2";       shift ;;
    --wg1-ip=*)    WG1_IP="${1#--wg1-ip=}" ;;
    --wg2-ip)      WG2_IP="$2";       shift ;;
    --wg2-ip=*)    WG2_IP="${1#--wg2-ip=}" ;;
    --wg3-ip)      WG3_IP="$2";       shift ;;
    --wg3-ip=*)    WG3_IP="${1#--wg3-ip=}" ;;
    --master-api)  MASTER_API="$2";   shift ;;
    --master-api=*) MASTER_API="${1#--master-api=}" ;;
    --retries)     RETRIES="$2";      shift ;;
    --retries=*)   RETRIES="${1#--retries=}" ;;
    --timeout)     TIMEOUT="$2";      shift ;;
    --timeout=*)   TIMEOUT="${1#--timeout=}" ;;
    -h|--help)
      sed -n '2,/^set /p' "$0" | grep '^#' | sed 's/^# \{0,2\}//'
      exit 0 ;;
    *) die "Unknown option: $1" ;;
  esac
  shift
done

[[ -n "${HOSTNAME_ARG}" ]] || HOSTNAME_ARG="$(hostname -s)"
[[ -n "${HOSTNAME_ARG}" ]] || die "--hostname is required"

# ── Build payload ─────────────────────────────────────────────────────────────
# JSON structure expected by debz-dns-api on the MASTER node:
# {
#   "hostname": "kvm-03",
#   "records": {
#     "node":  "10.78.1.3",    ← wg1 management plane primary A record
#     "wg0":   "10.77.1.3",
#     "wg1":   "10.78.1.3",
#     "wg2":   "10.79.1.3",
#     "wg3":   "10.80.1.3"
#   }
# }

PAYLOAD=$(printf '{"hostname":"%s","records":{"node":"%s","wg0":"%s","wg1":"%s","wg2":"%s","wg3":"%s"}}' \
  "${HOSTNAME_ARG}" \
  "${WG1_IP:-}" \
  "${WG0_IP:-}" \
  "${WG1_IP:-}" \
  "${WG2_IP:-}" \
  "${WG3_IP:-}")

log "Registering ${HOSTNAME_ARG} with master API at ${MASTER_API}"
log "  wg0=${WG0_IP:-unset}  wg1=${WG1_IP:-unset}  wg2=${WG2_IP:-unset}  wg3=${WG3_IP:-unset}"

# ── POST with retries ─────────────────────────────────────────────────────────
attempt=0
success=false

while (( attempt < RETRIES )); do
  (( attempt++ )) || true
  log "Attempt ${attempt}/${RETRIES} …"

  HTTP_CODE=$(curl \
    --silent \
    --max-time "${TIMEOUT}" \
    --output /tmp/debz-dns-register-resp.json \
    --write-out '%{http_code}' \
    --request POST \
    --header 'Content-Type: application/json' \
    --data "${PAYLOAD}" \
    "${MASTER_API}/api/dns/register" \
    2>>/var/log/debz/firstboot.log \
    || echo "000")

  if [[ "${HTTP_CODE}" == "200" || "${HTTP_CODE}" == "201" ]]; then
    success=true
    break
  fi

  RESP_BODY=""
  [[ -f /tmp/debz-dns-register-resp.json ]] \
    && RESP_BODY=$(cat /tmp/debz-dns-register-resp.json 2>/dev/null || true)

  warn "HTTP ${HTTP_CODE} from ${MASTER_API} — ${RESP_BODY}"

  if (( attempt < RETRIES )); then
    sleep $(( attempt * 2 ))   # 2s, 4s back-off
  fi
done

rm -f /tmp/debz-dns-register-resp.json

if [[ "${success}" == "true" ]]; then
  ok "DNS registered: ${HOSTNAME_ARG}.node.cluster.debz → ${WG1_IP:-?}"
  ok "              : ${HOSTNAME_ARG}.wg0.cluster.debz  → ${WG0_IP:-?}"
  ok "              : ${HOSTNAME_ARG}.wg2.cluster.debz  → ${WG2_IP:-?}"
  ok "              : ${HOSTNAME_ARG}.wg3.cluster.debz  → ${WG3_IP:-?}"

  # Write a local record so the node knows its own DNS name
  printf '%s.node.cluster.debz\n' "${HOSTNAME_ARG}" \
    > /etc/debz/cluster-fqdn
  chmod 0644 /etc/debz/cluster-fqdn

  exit 0
else
  warn "DNS registration failed after ${RETRIES} attempts"
  warn "Node will not appear in cluster.debz until master is reachable"
  warn "Re-run: debz-dns-register --hostname ${HOSTNAME_ARG} --wg1-ip ${WG1_IP:-?} --master-api ${MASTER_API}"
  exit 1
fi
