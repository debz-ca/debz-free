#!/usr/bin/env bash
set -Eeuo pipefail

LOG=/var/log/debz/bootstrap.log
mkdir -p /var/log/debz
touch "$LOG"

if ! command -v zfs >/dev/null 2>&1; then
  exit 0
fi

root_ds="$(zpool get -H -o value bootfs rpool 2>/dev/null || true)"
if [[ -n "$root_ds" && "$root_ds" != "-" ]]; then
  snap="${root_ds}@auto-$(date +%Y%m%d-%H%M%S)"
  {
    echo "[$(date '+%F %T')] creating snapshot ${snap}"
    zfs snapshot "$snap"
  } >>"$LOG" 2>&1 || true
fi
