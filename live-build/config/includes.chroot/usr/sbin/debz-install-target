#!/usr/bin/env bash
set -Eeuo pipefail

# Emergency cleanup — unmount /target if we abort mid-install
_emergency_cleanup() {
  local exit_code=$?
  [[ $exit_code -eq 0 ]] && return
  printf '\n\e[1;31m  ✖   Installation failed (exit %d) — cleaning up mounts\e[0m\n' "$exit_code" >&2
  local mnt="${DEBZ_TARGET_MNT:-/target}"
  # Unmount in reverse order
  umount -R "${mnt}" 2>/dev/null || true
  zpool export rpool 2>/dev/null || true
}
trap '_emergency_cleanup' ERR EXIT

k_poweroff_after_success() {
  # Callers (debz-deploy-tui, debz-installer-tui) may set DEBZ_SKIP_POWEROFF=1
  # to handle the poweroff/countdown themselves. Without it we power off here.
  if [[ "${DEBZ_SKIP_POWEROFF:-0}" == "1" ]]; then
    k_log "Install completed successfully (poweroff delegated to caller)"
    return 0
  fi
  k_log "Install completed successfully; ejecting media and powering off"
  sync || true
  eject 2>/dev/null || true
  sleep 2
  systemctl poweroff --no-wall 2>/dev/null || poweroff -f 2>/dev/null || shutdown -P now 2>/dev/null || true
}


if [[ "$(id -u)" -ne 0 ]]; then
  exec pkexec "$0" "$@"
fi

resolve_libdir() {
  if [[ -d /usr/lib/debz-installer/lib ]]; then
    printf '%s\n' /usr/lib/debz-installer/lib
    return 0
  fi
  local self_dir
  self_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  printf '%s\n' "${self_dir%/sbin}/lib"
}

LIB_DIR="$(resolve_libdir)"
export LIB_DIR

# Live lib modules (sourced in order):
#   common.sh    — k_log, k_die, k_bool, k_mount_bind helpers
#   logging.sh   — sets DEBZ_*_LOG paths, k_log_section
#   storage-zfs.sh — k_storage_zfs_install (ZFS pool + dataset creation)
#   bootstrap.sh — k_bootstrap_base (debootstrap, packages, locale, timezone)
#   profiles.sh  — k_profile_packages, k_install_system_files (called from bootstrap.sh)
#   bootloader.sh — k_install_bootloader (ZFSBootMenu EFI + GRUB)
#   answers.sh   — k_answers_load_env_file, k_save_effective_config
#
# All other functions (k_preflight, k_configure_network, k_configure_security,
# k_apply_profile, k_bind_chroot_mounts, k_list_candidate_disks, etc.) are
# defined as inline fallbacks below and are the authoritative implementations.
for f in \
  common.sh \
  logging.sh \
  storage-zfs.sh \
  profiles.sh \
  bootstrap.sh \
  security.sh \
  bootloader.sh \
  answers.sh \
  infra.sh
do
  if [[ -f "${LIB_DIR}/${f}" ]]; then
    # shellcheck source=/dev/null
    source "${LIB_DIR}/${f}"
  fi
done

: "${DEBZ_LOG_DIR:=/var/log/installer}"
: "${DEBZ_TARGET_MNT:=/target}"
: "${DEBZ_BOOTLOADER_ID:=Debz}"
export DEBZ_LOG_DIR DEBZ_TARGET_MNT DEBZ_BOOTLOADER_ID

mkdir -p "${DEBZ_LOG_DIR}"

k_have_func() { declare -F "$1" >/dev/null 2>&1; }

if ! k_have_func k_log; then
  k_log() {
    mkdir -p "${DEBZ_LOG_DIR}"
    printf '[%(%F %T)T] %s\n' -1 "$*" | tee -a "${DEBZ_LOG_DIR}/debz-installer.log" >&2
  }
fi

if ! k_have_func k_die; then
  k_die() { k_log "ERROR: $*"; exit 1; }
fi

if ! k_have_func k_answers_load_env_file; then
  k_answers_load_env_file() {
    local cfg="${1:?missing env file}"
    [[ -f "$cfg" ]] || k_die "answers file not found: $cfg"
    set -a
    # shellcheck source=/dev/null
    source "$cfg"
    set +a
  }
fi

if ! k_have_func k_save_effective_config; then
  k_save_effective_config() {
    local out="${DEBZ_LOG_DIR}/effective-config.env"
    : > "$out"
    env | sort | grep '^DEBZ_' >> "$out" || true
    chmod 0600 "$out"
    k_log "Saved effective config to ${out}"
  }
fi

if ! k_have_func k_list_candidate_disks; then
  k_list_candidate_disks() {
    echo "Available disks:"
    lsblk -d -e7,11 -n -o PATH,SIZE,MODEL
    echo
  }
fi

if ! k_have_func k_bind_chroot_mounts; then
  k_bind_chroot_mounts() {
    mkdir -p "${DEBZ_TARGET_MNT}"/{dev,proc,sys,run}
    mount --bind /dev   "${DEBZ_TARGET_MNT}/dev"
    mount --bind /proc  "${DEBZ_TARGET_MNT}/proc"
    mount --bind /sys   "${DEBZ_TARGET_MNT}/sys"
    mount --bind /run   "${DEBZ_TARGET_MNT}/run"
    if [[ -d /sys/firmware/efi/efivars ]]; then
      mkdir -p "${DEBZ_TARGET_MNT}/sys/firmware/efi/efivars"
      mount --bind /sys/firmware/efi/efivars "${DEBZ_TARGET_MNT}/sys/firmware/efi/efivars" || true
    fi
  }
fi

if ! k_have_func k_unbind_chroot_mounts; then
  k_unbind_chroot_mounts() {
    umount -lf "${DEBZ_TARGET_MNT}/sys/firmware/efi/efivars" 2>/dev/null || true
    umount -lf "${DEBZ_TARGET_MNT}/run"   2>/dev/null || true
    umount -lf "${DEBZ_TARGET_MNT}/sys"   2>/dev/null || true
    umount -lf "${DEBZ_TARGET_MNT}/proc"  2>/dev/null || true
    umount -lf "${DEBZ_TARGET_MNT}/dev"   2>/dev/null || true
  }
fi

if ! k_have_func k_preflight; then
  k_preflight() {
    k_log "========== Preflight =========="
    [[ -n "${DEBZ_DISK:-}" ]] || k_die "DEBZ_DISK is not set"
    [[ -b "${DEBZ_DISK}" ]]   || k_die "Target disk is not a block device: ${DEBZ_DISK}"

    local sb=0 tpm=0
    if command -v mokutil >/dev/null 2>&1; then
      mokutil --sb-state 2>/dev/null | grep -qi 'enabled' && sb=1
    fi
    [[ -e /dev/tpm0 || -e /dev/tpmrm0 ]] && tpm=1
    export DEBZ_SECURE_BOOT="${sb}" DEBZ_TPM_PRESENT="${tpm}"

    if [[ "${DEBZ_STORAGE_MODE:-zfs}" == "zfs" ]]; then
      command -v zpool >/dev/null 2>&1 && command -v zfs >/dev/null 2>&1 \
        || k_die "ZFS requested but zpool/zfs userspace is missing"
      if ! modprobe zfs >/dev/null 2>&1; then
        if [[ "${sb}" -eq 1 ]]; then
          if mokutil --list-new 2>/dev/null | grep -qi 'debz\|CN=debz'; then
            k_die "Secure Boot: MOK enrollment is pending — reboot, enroll in MokManager (password: debz), then run the installer"
          else
            k_die "Secure Boot: modprobe zfs failed — MOK not enrolled. Reboot the live ISO; it will automatically queue MOK enrollment"
          fi
        else
          k_die "ZFS requested but modprobe zfs failed — check dmesg for details"
        fi
      fi
    fi
    k_log "Preflight OK: secure_boot=${sb} tpm=${tpm}"
  }
fi


if ! k_have_func k_install_zfs_storage; then
  k_install_zfs_storage() {
    k_have_func k_storage_zfs_install \
      && { k_log "Invoking ZFS installer"; k_storage_zfs_install; } \
      || k_die "ZFS installer entrypoint not found"
  }
fi

if ! k_have_func k_bootstrap_base; then
  k_bootstrap_base() {
    : > "${DEBZ_LOG_DIR}/bootstrap.log"
    local suite="${DEBZ_DEBIAN_SUITE:-trixie}"
    local mirror="${DEBZ_DEBIAN_MIRROR:-https://mirror.it.ubc.ca/debian}"

    k_log "Bootstrapping Debian ${suite} → ${DEBZ_TARGET_MNT}"
    debootstrap --arch amd64 "${suite}" "${DEBZ_TARGET_MNT}" "${mirror}" \
      >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1

    cat > "${DEBZ_TARGET_MNT}/etc/apt/sources.list" <<EOS
deb ${mirror} ${suite} main contrib non-free-firmware
deb https://mirror.it.ubc.ca/debian ${suite}-updates main contrib non-free-firmware
deb http://security.debian.org/debian-security ${suite}-security main contrib non-free-firmware
EOS

    k_bind_chroot_mounts

    printf '#!/bin/sh\nexit 101\n' > "${DEBZ_TARGET_MNT}/usr/sbin/policy-rc.d"
    chmod 0755 "${DEBZ_TARGET_MNT}/usr/sbin/policy-rc.d"

    chroot "${DEBZ_TARGET_MNT}" apt-get update >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1
    DEBIAN_FRONTEND=noninteractive chroot "${DEBZ_TARGET_MNT}" apt-get install -y \
      linux-image-amd64 grub-efi-amd64 shim-signed efibootmgr \
      locales sudo openssh-server systemd-resolved network-manager \
      curl ca-certificates vim-tiny less iproute2 iputils-ping \
      initramfs-tools dosfstools e2fsprogs \
      keyboard-configuration console-setup tzdata \
      >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1

    # Locale
    local locale="${DEBZ_LOCALE:-en_US.UTF-8}"
    echo "${locale} UTF-8" > "${DEBZ_TARGET_MNT}/etc/locale.gen"
    chroot "${DEBZ_TARGET_MNT}" locale-gen >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1
    printf 'LANG=%s\nLC_ALL=%s\n' "${locale}" "${locale}" \
      > "${DEBZ_TARGET_MNT}/etc/default/locale"

    # Keyboard
    local kblayout="${DEBZ_KEYBOARD_LAYOUT:-us}"
    local kbvariant="${DEBZ_KEYBOARD_VARIANT:-}"
    cat > "${DEBZ_TARGET_MNT}/etc/default/keyboard" <<EOS
XKBMODEL="pc105"
XKBLAYOUT="${kblayout}"
XKBVARIANT="${kbvariant}"
XKBOPTIONS=""
BACKSPACE="guess"
EOS
    DEBIAN_FRONTEND=noninteractive chroot "${DEBZ_TARGET_MNT}" \
      dpkg-reconfigure -f noninteractive keyboard-configuration \
      >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1 || true

    # Timezone
    local tz="${DEBZ_TIMEZONE:-UTC}"
    if [[ -f "${DEBZ_TARGET_MNT}/usr/share/zoneinfo/${tz}" ]]; then
      ln -sf "/usr/share/zoneinfo/${tz}" "${DEBZ_TARGET_MNT}/etc/localtime"
      echo "${tz}" > "${DEBZ_TARGET_MNT}/etc/timezone"
      DEBIAN_FRONTEND=noninteractive chroot "${DEBZ_TARGET_MNT}" \
        dpkg-reconfigure -f noninteractive tzdata \
        >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1 || true
      k_log "Timezone: ${tz}"
    else
      k_log "Warning: timezone '${tz}' not found, using UTC"
      ln -sf /usr/share/zoneinfo/UTC "${DEBZ_TARGET_MNT}/etc/localtime"
      echo "UTC" > "${DEBZ_TARGET_MNT}/etc/timezone"
    fi

    # Extra packages
    if [[ -n "${DEBZ_EXTRA_PACKAGES:-}" ]]; then
      k_log "Installing extra packages: ${DEBZ_EXTRA_PACKAGES}"
      IFS=', ' read -r -a _extra <<< "${DEBZ_EXTRA_PACKAGES}"
      DEBIAN_FRONTEND=noninteractive chroot "${DEBZ_TARGET_MNT}" \
        apt-get install -y "${_extra[@]}" \
        >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1 \
        || k_log "Warning: some extra packages failed to install"
    fi

    rm -f "${DEBZ_TARGET_MNT}/usr/sbin/policy-rc.d"
    k_log "Base bootstrap complete"
  }
fi

if ! k_have_func k_configure_network; then
  k_configure_network() {
    : > "${DEBZ_LOG_DIR}/network.log"
    local hostname="${DEBZ_HOSTNAME:-debz}"

    echo "${hostname}" > "${DEBZ_TARGET_MNT}/etc/hostname"
    cat > "${DEBZ_TARGET_MNT}/etc/hosts" <<EOS
127.0.0.1 localhost
127.0.1.1 ${hostname}
::1 localhost ip6-localhost ip6-loopback
EOS

    mkdir -p "${DEBZ_TARGET_MNT}/etc/NetworkManager/system-connections"

    if [[ "${DEBZ_NET_METHOD:-dhcp}" == "static" ]]; then
      local iface="${DEBZ_NET_IFACE:-eth0}"
      local ip="${DEBZ_NET_IP:?static IP required}"
      local prefix="${DEBZ_NET_PREFIX:-24}"
      local gw="${DEBZ_NET_GW:?gateway required}"
      local dns="${DEBZ_NET_DNS:-1.1.1.1,8.8.8.8}"
      k_log "Static IP: ${ip}/${prefix} gw=${gw} dns=${dns}"
      cat > "${DEBZ_TARGET_MNT}/etc/NetworkManager/system-connections/debz-static.nmconnection" <<EOS
[connection]
id=debz-static
type=ethernet
interface-name=${iface}
autoconnect=true

[ethernet]

[ipv4]
method=manual
addresses=${ip}/${prefix}
gateway=${gw}
dns=${dns}

[ipv6]
method=auto
EOS
      chmod 0600 "${DEBZ_TARGET_MNT}/etc/NetworkManager/system-connections/debz-static.nmconnection"
    else
      k_log "Network: DHCP"
      cat > "${DEBZ_TARGET_MNT}/etc/NetworkManager/system-connections/debz-dhcp.nmconnection" <<EOS
[connection]
id=debz-dhcp
type=ethernet
autoconnect=true

[ethernet]

[ipv4]
method=auto

[ipv6]
method=auto
EOS
      chmod 0600 "${DEBZ_TARGET_MNT}/etc/NetworkManager/system-connections/debz-dhcp.nmconnection"
    fi

    chroot "${DEBZ_TARGET_MNT}" systemctl enable NetworkManager \
      >> "${DEBZ_LOG_DIR}/network.log" 2>&1 || true
    k_log "Network configuration complete"
  }
fi

if ! k_have_func k_configure_security; then
  k_configure_security() {
    : > "${DEBZ_LOG_DIR}/security.log"
    local user="${DEBZ_USERNAME:-admin}"
    local upass="${DEBZ_PASSWORD:-admin}"

    chroot "${DEBZ_TARGET_MNT}" useradd -m -s /bin/bash "${user}" \
      >> "${DEBZ_LOG_DIR}/security.log" 2>&1 || true
    echo "${user}:${upass}" | chroot "${DEBZ_TARGET_MNT}" chpasswd >> "${DEBZ_LOG_DIR}/security.log" 2>&1
    chroot "${DEBZ_TARGET_MNT}" usermod -aG sudo "${user}" >> "${DEBZ_LOG_DIR}/security.log" 2>&1 || true

    # Passwordless sudo for the admin user
    printf '%s ALL=(ALL) NOPASSWD: ALL\n' "${user}" \
      > "${DEBZ_TARGET_MNT}/etc/sudoers.d/debz-admin"
    chmod 0440 "${DEBZ_TARGET_MNT}/etc/sudoers.d/debz-admin"

    mkdir -p "${DEBZ_TARGET_MNT}/etc/ssh/sshd_config.d"
    cat > "${DEBZ_TARGET_MNT}/etc/ssh/sshd_config.d/10-debz.conf" <<'EOS'
PermitRootLogin prohibit-password
PasswordAuthentication yes
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
UsePAM yes
EOS
    chroot "${DEBZ_TARGET_MNT}" systemctl enable ssh >> "${DEBZ_LOG_DIR}/security.log" 2>&1 || true

    # Install SSH public keys if provided
    if [[ -n "${DEBZ_SSH_PUBKEY:-}" ]]; then
      local user_ssh_dir="${DEBZ_TARGET_MNT}/home/${user}/.ssh"
      mkdir -p "${user_ssh_dir}"
      printf '%s\n' "${DEBZ_SSH_PUBKEY}" >> "${user_ssh_dir}/authorized_keys"
      chmod 0700 "${user_ssh_dir}"
      chmod 0600 "${user_ssh_dir}/authorized_keys"
      chroot "${DEBZ_TARGET_MNT}" chown -R "${user}:${user}" "/home/${user}/.ssh"
      k_log "SSH pubkey installed for ${user}"
    fi
    if [[ -n "${DEBZ_ADMIN_SSH_PUBKEY:-}" ]]; then
      local root_ssh_dir="${DEBZ_TARGET_MNT}/root/.ssh"
      mkdir -p "${root_ssh_dir}"
      printf '%s\n' "${DEBZ_ADMIN_SSH_PUBKEY}" >> "${root_ssh_dir}/authorized_keys"
      chmod 0700 "${root_ssh_dir}"
      chmod 0600 "${root_ssh_dir}/authorized_keys"
      k_log "Admin SSH pubkey installed for root"
    fi

    k_log "Security configuration complete"
  }
fi

if ! k_have_func k_apply_profile; then
  k_apply_profile() {
    local profile="${DEBZ_PROFILE:-server}"
    local template="${DEBZ_TEMPLATE:-}"

    # ZFS packages must be in every installed system regardless of profile
    local pkgs=(
        zfsutils-linux zfs-dkms zfs-initramfs zfs-zed
        curl ca-certificates openssh-server
        wireguard-tools
        chrony nftables htop ethtool tcpdump
    )

    case "${profile}" in
      server|client)
        pkgs+=(bpftrace bpfcc-tools)
        ;;
      desktop)
        pkgs+=(task-gnome-desktop gdm3 firefox-esr bpftrace bpfcc-tools)
        ;;
      master)
        # Full desktop + all central-command management infrastructure
        pkgs+=(task-gnome-desktop gdm3 firefox-esr bpftrace bpfcc-tools)
        pkgs+=(salt-master salt-minion nginx dnsmasq python3-aiohttp python3-websockets sqlite3)
        ;;
    esac

    # Template-specific packages installed at provision time (from standard Debian repos)
    case "${template}" in
      proxmox)
        pkgs+=(bridge-utils ifupdown2 vlan)
        ;;
      kvm)
        pkgs+=(qemu-kvm libvirt-daemon-system libvirt-clients bridge-utils virt-top cpu-checker)
        ;;
      etcd)
        pkgs+=(etcd)
        ;;
      worker)
        pkgs+=(containerd socat conntrack ipvsadm)
        ;;
      firewall)
        pkgs+=(ipset conntrack-tools keepalived unbound unbound-anchor knot knot-dnsutils)
        ;;
      monitoring)
        pkgs+=(prometheus prometheus-node-exporter)
        ;;
    esac

    k_log "Installing profile packages: profile=${profile} template=${template:-none}"
    DEBIAN_FRONTEND=noninteractive chroot "${DEBZ_TARGET_MNT}" \
      apt-get install -y "${pkgs[@]}" >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1 \
      || k_log "WARNING: some profile packages failed to install — check bootstrap.log"

    # Enable desktop display manager for desktop and master profiles
    if [[ "${profile}" == "desktop" || "${profile}" == "master" ]]; then
      chroot "${DEBZ_TARGET_MNT}" systemctl enable gdm3 >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1 || true
    fi

    # Master profile: enable all central-command services and write node identity
    if [[ "${profile}" == "master" ]]; then
      k_log "Enabling master node services (webui, reconcile, apt-mirror, salt-master)"
      for svc in debz-webui.service debz-reconcile.service debz-apt-mirror.service debz-apt-snapshot.path salt-master.service; do
        chroot "${DEBZ_TARGET_MNT}" systemctl enable "${svc}" >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1 \
          || k_log "WARNING: could not enable ${svc}"
      done
      # Mark this node as master in node.env so debz-webui detects master mode
      mkdir -p "${DEBZ_TARGET_MNT}/etc/debz"
      cat > "${DEBZ_TARGET_MNT}/etc/debz/node.env" <<NODEENV
DEBZ_NODE_ROLE=master
DEBZ_NODE_HOSTNAME=${DEBZ_HOSTNAME}
DEBZ_UI_TITLE=Central Command
NODEENV
      k_log "node.env written: role=master hostname=${DEBZ_HOSTNAME}"
    fi

    k_log "Profile packages installed: profile=${profile} template=${template:-none}"
  }
fi

if ! k_have_func k_install_tools; then
  k_install_tools() {
    local target="${DEBZ_TARGET_MNT}"
    local log="${DEBZ_LOG_DIR}/bootstrap.log"
    k_log "Installing management tools to target"

    # /usr/sbin management binaries
    local sbin_dst="${target}/usr/sbin"
    mkdir -p "${sbin_dst}"
    for f in debz-firstboot debz-recovery debz-snapshot debz-apply-platform-holds; do
      [[ -f "/usr/sbin/${f}" ]] || continue
      install -m 0755 "/usr/sbin/${f}" "${sbin_dst}/${f}"
      printf '  installed: /usr/sbin/%s\n' "${f}" >> "${log}"
    done

    # /usr/local/sbin snapshot scripts
    local lsbin_dst="${target}/usr/local/sbin"
    mkdir -p "${lsbin_dst}"
    for f in snapshot-create.sh snapshot-prune.sh snapshot-policy.sh; do
      [[ -f "/usr/local/sbin/${f}" ]] || continue
      install -m 0755 "/usr/local/sbin/${f}" "${lsbin_dst}/${f}"
      printf '  installed: /usr/local/sbin/%s\n' "${f}" >> "${log}"
    done

    # /usr/local/sbin debz-* scripts (exclude live-only)
    for f in /usr/local/sbin/debz-*; do
      [[ -f "${f}" ]] || continue
      local base
      base="$(basename "${f}")"
      case "${base}" in
        debz-live-*|debz-deploy-tui) continue ;;
      esac
      install -m 0755 "${f}" "${lsbin_dst}/${base}"
      printf '  installed: /usr/local/sbin/%s\n' "${base}" >> "${log}"
    done

    # APT snapshot hooks
    local apt_dst="${target}/etc/apt/apt.conf.d"
    mkdir -p "${apt_dst}"
    for f in 00-debz-snapshot-pre 00-debz-snapshot-post; do
      [[ -f "/etc/apt/apt.conf.d/${f}" ]] || continue
      install -m 0644 "/etc/apt/apt.conf.d/${f}" "${apt_dst}/${f}"
      printf '  installed: /etc/apt/apt.conf.d/%s\n' "${f}" >> "${log}"
    done

    # systemd units for the installed system (exclude live-only services)
    local unit_dst="${target}/usr/lib/systemd/system"
    mkdir -p "${unit_dst}"
    local -a target_units=(
      debz-firstboot.service
      debz-snapshot.service debz-snapshot.timer
      debz-srv-snapshot.service debz-srv-snapshot.timer
      debz-autobootstrap.service debz-autobootstrap.timer
      debz-dns-api.service
    )
    for u in "${target_units[@]}"; do
      [[ -f "/usr/lib/systemd/system/${u}" ]] || continue
      install -m 0644 "/usr/lib/systemd/system/${u}" "${unit_dst}/${u}"
      printf '  installed: /usr/lib/systemd/system/%s\n' "${u}" >> "${log}"
    done

    k_log "Management tools installed to target"
  }
fi

if ! k_have_func k_write_install_manifest; then
  k_write_install_manifest() {
    local target="${DEBZ_TARGET_MNT}"
    mkdir -p "${target}/etc/debz"
    cat > "${target}/etc/debz/install-manifest.env" <<EOF
# Debz Install Manifest — written by installer $(date -u '+%Y-%m-%dT%H:%M:%SZ')
DEBZ_INSTALL_DATE="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
DEBZ_INSTALL_DISK="${DEBZ_DISK:-}"
DEBZ_PROFILE="${DEBZ_PROFILE:-server}"
DEBZ_TEMPLATE="${DEBZ_TEMPLATE:-}"
DEBZ_HOSTNAME="${DEBZ_HOSTNAME:-debz}"
DEBZ_USERNAME="${DEBZ_USERNAME:-admin}"
DEBZ_NET_METHOD="${DEBZ_NET_METHOD:-dhcp}"
DEBZ_NET_IFACE="${DEBZ_NET_IFACE:-}"
DEBZ_NET_IP="${DEBZ_NET_IP:-}"
DEBZ_NET_PREFIX="${DEBZ_NET_PREFIX:-}"
DEBZ_NET_GW="${DEBZ_NET_GW:-}"
DEBZ_NET_DNS="${DEBZ_NET_DNS:-}"
DEBZ_STORAGE_MODE="${DEBZ_STORAGE_MODE:-zfs}"
DEBZ_ZFS_TOPOLOGY="${DEBZ_ZFS_TOPOLOGY:-single}"
DEBZ_ZFS_ENCRYPT="${DEBZ_ZFS_ENCRYPT:-0}"
DEBZ_DEBIAN_RELEASE="${DEBZ_DEBIAN_RELEASE:-trixie}"
DEBZ_INSTALLER_VERSION="1.0.0"
# Deployment intent: standalone | cluster-manager | join
DEBZ_INFRA_MODE="${DEBZ_INFRA_MODE:-standalone}"
# For join mode: LAN IP of the Cluster Manager to connect to at first boot
DEBZ_HUB_LAN="${DEBZ_HUB_LAN:-}"
EOF
    chmod 0640 "${target}/etc/debz/install-manifest.env"
    k_log "Install manifest written: ${target}/etc/debz/install-manifest.env"
  }
fi

if ! k_have_func k_enable_firstboot; then
  k_enable_firstboot() {
    local target="${DEBZ_TARGET_MNT}"
    chroot "${target}" systemctl enable debz-firstboot.service \
      >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1 \
      || k_log "WARNING: could not enable debz-firstboot.service"
    k_log "debz-firstboot.service enabled"
  }
fi

if ! k_have_func k_seed_ca; then
  k_seed_ca() {
    local target="${DEBZ_TARGET_MNT}"
    local iso_ca="/etc/debz/ca/ca.crt"
    if [[ -f "${iso_ca}" ]]; then
      mkdir -p "${target}/etc/debz/ca" "${target}/usr/local/share/ca-certificates"
      cp "${iso_ca}" "${target}/etc/debz/ca/ca.crt"
      cp "${iso_ca}" "${target}/usr/local/share/ca-certificates/debz-ca.crt"
      chmod 0644 "${target}/etc/debz/ca/ca.crt" \
                 "${target}/usr/local/share/ca-certificates/debz-ca.crt"
      chroot "${target}" update-ca-certificates \
        >> "${DEBZ_LOG_DIR}/bootstrap.log" 2>&1 || true
      k_log "ISO CA cert seeded to target"
    else
      k_log "No ISO CA at ${iso_ca} — skipping CA seeding"
    fi
  }
fi

cleanup() {
  local rc=$?
  sync || true
  k_unbind_chroot_mounts || true
  umount -lf "${DEBZ_TARGET_MNT}/boot/efi" 2>/dev/null || true
  umount -lf "${DEBZ_TARGET_MNT}"          2>/dev/null || true
  [[ "$rc" -ne 0 ]] && k_log "Install FAILED (exit ${rc})"
  return "$rc"
}

usage() { cat <<'EOU'
Usage:
  debz-install-target --config /path/to/answers.env
  debz-install-target --guided
EOU
}

# ── UI helpers ────────────────────────────────────────────────────────────────

# Horizontal rule — bright blue
_bar() {
  printf '\n\e[1;34m  ══════════════════════════════════════════════════════\e[0m\n'
}

# Section header — bright blue bar + bold white title
_hdr() {
  _bar
  printf '\e[1;37m  %s\e[0m\n' "$*"
  _bar
  echo
}

# Question prompt — bold white arrow + label, bright green default, white colon
# Adds a blank line before each question so they breathe
_ask() {
  local prompt="$1" default="${2:-}" v
  # Write prompt to stderr — _ask is called inside $() so stdout is captured.
  # Prompt must go to stderr to be visible on the terminal.
  echo >&2
  if [[ -n "$default" ]]; then
    printf '\e[1;37m  ›  %s \e[1;32m[%s]\e[1;37m: \e[0m' "$prompt" "$default" >&2
  else
    printf '\e[1;37m  ›  %s: \e[0m' "$prompt" >&2
  fi
  read -r v
  echo "${v:-$default}"
}

# Password prompt — same style, no echo
_askpass() {
  local prompt="$1" v
  echo >&2
  printf '\e[1;37m  ›  %s: \e[0m' "$prompt" >&2
  read -r -s v
  echo >&2
  echo "$v"
}

# Info / example line — regular white (NOT dim)
_info() { printf '  \e[0;37m%s\e[0m\n' "$*"; }

# Example with highlight — white label + bright cyan value
_eg()   { printf '  \e[0;37m  e.g. \e[1;36m%s\e[0m\n' "$*"; }

# Warning — bright yellow
_warn() { printf '\n  \e[1;33m⚠   %s\e[0m\n' "$*"; }

# Confirmed value — bright green tick
_ok()   { printf '  \e[1;32m✔   %-12s\e[0;37m %s\e[0m\n' "$1" "$2"; }

# Error — bright red
_err()  { printf '\n  \e[1;31m✖   %s\e[0m\n' "$*"; }

# ── Auto-detect first available disk ─────────────────────────────────────────
_detect_first_disk() {
  local candidates=(/dev/sda /dev/vda /dev/xvda /dev/nvme0n1 /dev/mmcblk0 /dev/hda)
  for dev in "${candidates[@]}"; do
    [[ -b "$dev" ]] && { echo "$dev"; return 0; }
  done
  # Fallback: first disk reported by lsblk
  lsblk -d -e7 -n -o PATH,TYPE 2>/dev/null \
    | awk '$2=="disk" {print $1; exit}'
}

# ── Disk list ─────────────────────────────────────────────────────────────────
k_list_candidate_disks() {
  printf '\e[1;37m  %-20s %-8s %-30s\e[0m\n' "DEVICE" "SIZE" "MODEL"
  printf '\e[1;34m  %-20s %-8s %-30s\e[0m\n' "──────────────────" "────────" "──────────────────────────────"
  lsblk -d -e7,11 -n -o PATH,SIZE,MODEL 2>/dev/null \
    | while read -r dev size model; do
        printf "\033[1;36m  %-20s \033[1;32m%-8s \033[0;37m%-30s\033[0m\n" \
          "$dev" "$size" "$model"
      done
  echo
}

guided_defaults() {
  export DEBZ_PROFILE="${DEBZ_PROFILE:-server}"
  export DEBZ_STORAGE_MODE="${DEBZ_STORAGE_MODE:-zfs}"
  export DEBZ_ENABLE_ZFS="${DEBZ_ENABLE_ZFS:-1}"
  export DEBZ_ZFS_ENCRYPT="${DEBZ_ZFS_ENCRYPT:-0}"
  export DEBZ_ZFS_TOPOLOGY="${DEBZ_ZFS_TOPOLOGY:-single}"
  export DEBZ_ZFS_DATA_DISKS="${DEBZ_ZFS_DATA_DISKS:-}"
  export DEBZ_ZFS_SPECIAL_DISKS="${DEBZ_ZFS_SPECIAL_DISKS:-}"
  export DEBZ_HOSTNAME="${DEBZ_HOSTNAME:-debz}"
  export DEBZ_NET_METHOD="${DEBZ_NET_METHOD:-dhcp}"
  export DEBZ_ENABLE_EBPF="${DEBZ_ENABLE_EBPF:-1}"
  export DEBZ_FORCE_WIPE="${DEBZ_FORCE_WIPE:-1}"
  export DEBZ_BOOTLOADER_ID="${DEBZ_BOOTLOADER_ID:-Debz}"
  export DEBZ_KEYBOARD_LAYOUT="${DEBZ_KEYBOARD_LAYOUT:-us}"
  export DEBZ_KEYBOARD_VARIANT="${DEBZ_KEYBOARD_VARIANT:-}"
  export DEBZ_TIMEZONE="${DEBZ_TIMEZONE:-UTC}"
  export DEBZ_LOCALE="${DEBZ_LOCALE:-en_US.UTF-8}"
  export DEBZ_EXTRA_PACKAGES="${DEBZ_EXTRA_PACKAGES:-}"
  export DEBZ_KEEP_DARKSITE="${DEBZ_KEEP_DARKSITE:-0}"
  export DEBZ_CUSTOM_MIRROR_URL="${DEBZ_CUSTOM_MIRROR_URL:-}"
  export DEBZ_INFRA_MODE="${DEBZ_INFRA_MODE:-standalone}"
  export DEBZ_CLUSTER_CIDR="${DEBZ_CLUSTER_CIDR:-}"
  export DEBZ_CLUSTER_DOMAIN="${DEBZ_CLUSTER_DOMAIN:-infra.local}"
  export DEBZ_CLUSTER_SIZE="${DEBZ_CLUSTER_SIZE:-16}"
  export DEBZ_GENERATE_SSH_KEY="${DEBZ_GENERATE_SSH_KEY:-1}"
}

guided_prompt() {
  guided_defaults

  clear

  local v

  # ── 1 of 6 · Identity & Credentials ─────────────────────────────────────
  # Collected first so the username is available for ZFS home dataset creation
  # (rpool/home/<username> is created as a dedicated dataset at pool setup time).
  _hdr "1 of 6  ·  Identity & Credentials"

  _info "Hostname is used as the machine name on the network."
  DEBZ_HOSTNAME="$(_ask "Hostname" "debz")"
  export DEBZ_HOSTNAME

  echo
  _info "Profile determines which packages are installed:"
  _info "  server   —  headless, SSH, eBPF tools            (default)"
  _info "  desktop  —  GNOME desktop, GDM, Firefox, eBPF tools"
  _info "  master   —  Central Command: desktop + salt-master + webui + reconcile"
  v="$(_ask "Profile" "server")"
  export DEBZ_PROFILE="${v:-server}"

  echo
  _info "Admin user — this account gets passwordless sudo. Root login is disabled."
  DEBZ_USERNAME="$(_ask "Admin username" "admin")"
  export DEBZ_USERNAME
  while true; do
    DEBZ_PASSWORD="$(_askpass "Password")"
    local _pw_confirm
    _pw_confirm="$(_askpass "Confirm password")"
    [[ "$DEBZ_PASSWORD" == "$_pw_confirm" ]] && break
    _err "Passwords do not match — try again."
  done
  export DEBZ_PASSWORD

  _ok "Hostname"   "${DEBZ_HOSTNAME}"
  _ok "Profile"    "${DEBZ_PROFILE}"
  _ok "User"       "${DEBZ_USERNAME}  (passwordless sudo · home dataset: rpool/home/${DEBZ_USERNAME})"

  # ── 2 of 6 · Disk & Pool Layout ──────────────────────────────────────────
  _hdr "2 of 6  ·  Disk & Pool Layout"
  k_list_candidate_disks

  _info "Pool layout — select one:"
  _info ""
  _info "  single         boot disk only: EFI + bpool + rpool on one disk"
  _info "  mirror         2-disk mirror   (rpool: 2 data disks · boot stays on sda)"
  _info "  raidz1         4-disk RAIDZ1   (rpool: 4 data disks · boot stays on sda)"
  _info "  mirror-stripe  4-disk RAID10   (rpool: sdb+sdc mirror ║ sdd+sde mirror)"
  _info ""
  _info "Extra disks (scsi1–4) are used as rpool data disks for multi-disk topologies."
  _info "Remaining disks (scsi5–6) are offered as special vdevs (metadata acceleration)."

  local _topo
  _topo="$(_ask "Pool layout" "single")"
  case "${_topo}" in
    single|mirror|raidz1|mirror-stripe) export DEBZ_ZFS_TOPOLOGY="${_topo}" ;;
    *) _err "Unknown layout '${_topo}'. Valid: single mirror raidz1 mirror-stripe"; exit 1 ;;
  esac

  local _default_disk
  _default_disk="$(_detect_first_disk)"
  _warn "The boot disk will be completely wiped."
  DEBZ_DISK="$(_ask "Boot disk" "${_default_disk}")"
  [[ -b "${DEBZ_DISK}" ]] || { _err "Not a valid block device: ${DEBZ_DISK}"; exit 1; }
  export DEBZ_DISK

  if [[ "${DEBZ_ZFS_TOPOLOGY}" != "single" ]]; then
    # Collect all block disks except the boot disk, in sorted order
    local -a _all_disks=()
    mapfile -t _all_disks < <(lsblk -d -e7,11 -n -o PATH 2>/dev/null | sort)
    local -a _data_candidates=()
    local _d
    for _d in "${_all_disks[@]}"; do
      [[ "${_d}" != "${DEBZ_DISK}" ]] && _data_candidates+=("${_d}")
    done

    local _needed_data
    case "${DEBZ_ZFS_TOPOLOGY}" in
      mirror)        _needed_data=2 ;;
      raidz1)        _needed_data=4 ;;
      mirror-stripe) _needed_data=4 ;;
    esac

    local _default_data="${_data_candidates[*]:0:${_needed_data}}"
    _info ""
    _info "Data disks for the rpool (space-separated, need ${_needed_data}):"
    DEBZ_ZFS_DATA_DISKS="$(_ask "Pool disks" "${_default_data}")"
    export DEBZ_ZFS_DATA_DISKS

    # Offer remaining disks as special vdevs
    # shellcheck disable=SC2206
    local -a _used=(${DEBZ_ZFS_DATA_DISKS})
    local -a _special_candidates=()
    local _u _in_use
    for _d in "${_data_candidates[@]}"; do
      _in_use=0
      for _u in "${_used[@]}"; do [[ "${_d}" == "${_u}" ]] && _in_use=1 && break; done
      [[ ${_in_use} -eq 0 ]] && _special_candidates+=("${_d}")
    done

    if [[ ${#_special_candidates[@]} -ge 1 ]]; then
      local _default_special
      _default_special="${_special_candidates[*]:0:2}"
      _info ""
      _info "Special vdev disks — accelerate metadata and small blocks (optional)."
      _info "Detected candidates: ${_default_special}"
      local _use_special
      _use_special="$(_ask "Add special vdevs" "yes")"
      if [[ "${_use_special}" == "yes" || "${_use_special}" == "y" ]]; then
        DEBZ_ZFS_SPECIAL_DISKS="$(_ask "Special vdev disks" "${_default_special}")"
        export DEBZ_ZFS_SPECIAL_DISKS
        _ok "Special vdevs" "${DEBZ_ZFS_SPECIAL_DISKS}"
      fi
    fi

    _ok "Pool layout"  "${DEBZ_ZFS_TOPOLOGY}"
    _ok "Boot disk"    "${DEBZ_DISK}"
    _ok "Pool disks"   "${DEBZ_ZFS_DATA_DISKS}"
  else
    _ok "Pool layout"  "single  (${DEBZ_DISK})"
  fi

  # ── 3 of 6 · Encryption ──────────────────────────────────────────────────
  _hdr "3 of 6  ·  ZFS Encryption"
  _info "debz installs ZFS on root for snapshots, boot environments, and replication."
  _info ""
  _info "  zfs      —  ZFS, no encryption  (default)"
  _info "  zfs-enc  —  ZFS with full dataset encryption (you will be prompted for a passphrase)"
  v="$(_ask "Storage mode" "zfs")"
  case "${v}" in
    zfs-enc|zfs-encrypt|enc|encrypted)
      export DEBZ_STORAGE_MODE=zfs DEBZ_ENABLE_ZFS=1 DEBZ_ZFS_ENCRYPT=1
      DEBZ_ZFS_PASSPHRASE="$(_askpass "ZFS encryption passphrase")"
      export DEBZ_ZFS_PASSPHRASE
      _ok "Encryption" "enabled"
      ;;
    *)
      export DEBZ_STORAGE_MODE=zfs DEBZ_ENABLE_ZFS=1 DEBZ_ZFS_ENCRYPT=0
      _ok "Encryption" "disabled"
      ;;
  esac

  # ── 4 of 6 · Keyboard & Locale ───────────────────────────────────────────
  _hdr "4 of 6  ·  Keyboard & Locale"
  _info "Keyboard layout controls key mapping for the installed system."
  _eg  "us  gb  de  fr  es  it  pt  ru  jp"
  DEBZ_KEYBOARD_LAYOUT="$(_ask "Keyboard layout" "us")"
  export DEBZ_KEYBOARD_LAYOUT

  _info ""
  _info "Variant is optional — leave blank for the standard layout."
  _eg  "dvorak  colemak  intl  nodeadkeys"
  DEBZ_KEYBOARD_VARIANT="$(_ask "Keyboard variant" "")"
  export DEBZ_KEYBOARD_VARIANT

  _info ""
  _info "Locale controls language and number/date formats."
  _eg  "en_US.UTF-8  en_GB.UTF-8  de_DE.UTF-8  fr_FR.UTF-8"
  DEBZ_LOCALE="$(_ask "System locale" "en_US.UTF-8")"
  export DEBZ_LOCALE

  # ── 5 of 6 · Timezone ────────────────────────────────────────────────────
  _hdr "5 of 6  ·  Timezone"
  _info "Use the standard tz database format."
  _eg  "UTC  America/New_York  America/Los_Angeles  America/Chicago"
  _eg  "Europe/London  Europe/Berlin  Asia/Tokyo  Australia/Sydney"
  DEBZ_TIMEZONE="$(_ask "Timezone" "UTC")"
  export DEBZ_TIMEZONE

  # ── 6 of 6 · Network ─────────────────────────────────────────────────────
  _hdr "6 of 6  ·  Network"
  _info "DHCP works for most setups. Choose static if this host needs a fixed IP."
  _eg  "dhcp  or  static"
  v="$(_ask "Network mode" "dhcp")"
  export DEBZ_NET_METHOD="${v:-dhcp}"

  if [[ "${DEBZ_NET_METHOD}" == "static" ]]; then
    _eg "eth0  ens3  enp2s0"
    DEBZ_NET_IFACE="$(_ask "Interface name" "eth0")"; export DEBZ_NET_IFACE
    _eg "192.168.1.10"
    DEBZ_NET_IP="$(_ask "IP address")"; export DEBZ_NET_IP
    DEBZ_NET_PREFIX="$(_ask "Prefix length" "24")"; export DEBZ_NET_PREFIX
    _eg "192.168.1.1"
    DEBZ_NET_GW="$(_ask "Gateway")"; export DEBZ_NET_GW
    _eg "1.1.1.1,8.8.8.8"
    DEBZ_NET_DNS="$(_ask "DNS servers" "1.1.1.1,8.8.8.8")"; export DEBZ_NET_DNS
    _ok "Network" "static  ${DEBZ_NET_IP}/${DEBZ_NET_PREFIX}"
  else
    _ok "Network" "DHCP"
  fi

  # ── Extra packages ────────────────────────────────────────────────────────
  _bar
  printf '\n\e[1;37m  Extra Packages\e[0m\n\n'
  _info "Additional packages to install — space or comma separated. Leave blank to skip."
  _eg  "htop git tmux wireguard-tools docker.io"
  DEBZ_EXTRA_PACKAGES="$(_ask "Extra packages" "")"; export DEBZ_EXTRA_PACKAGES

  # ── APT mirror for updates ────────────────────────────────────────────────
  _bar
  printf '\n\e[1;37m  Package Updates\e[0m\n\n'
  _info "After install, the target system needs an APT source for future updates."
  _info ""
  _info "  internet  — standard Debian repos (deb.debian.org)         (default)"
  _info "  custom    — your own APT mirror URL (air-gap / private DC)"
  _info ""
  _info "The installation itself always uses the fast local darksite mirror."
  _info "This setting only affects the installed system's update source."
  local _mirror_mode
  _mirror_mode="$(_ask "Update source" "internet")"
  if [[ "${_mirror_mode}" == "custom" ]]; then
    _eg "http://apt.internal/debian  or  http://10.0.0.1:3142/apt"
    DEBZ_CUSTOM_MIRROR_URL="$(_ask "Mirror URL")"
    if [[ -n "${DEBZ_CUSTOM_MIRROR_URL}" ]]; then
      export DEBZ_KEEP_DARKSITE=1
      export DEBZ_CUSTOM_MIRROR_URL
      _ok "Updates" "custom mirror: ${DEBZ_CUSTOM_MIRROR_URL}"
    else
      export DEBZ_KEEP_DARKSITE=0
      _warn "No URL entered — falling back to standard Debian internet repos"
      _ok "Updates" "internet (deb.debian.org)"
    fi
  else
    export DEBZ_KEEP_DARKSITE=0
    _ok "Updates" "internet (deb.debian.org)"
  fi

  # ── Infrastructure mode (screens 7–13) ───────────────────────────────────
  if k_have_func guided_infra_prompt; then
    guided_infra_prompt
  fi

  # ── Summary ───────────────────────────────────────────────────────────────
  _bar
  printf '\n\e[1;37m  Install Summary\e[0m\n\n'
  _ok "User:"      "${DEBZ_USERNAME}  (passwordless sudo)"
  _ok "Hostname:"  "${DEBZ_HOSTNAME}"
  _ok "Profile:"   "${DEBZ_PROFILE}"
  _ok "Disk:"      "${DEBZ_DISK}"
  _ok "Topology:"  "${DEBZ_ZFS_TOPOLOGY}${DEBZ_ZFS_DATA_DISKS:+  ·  ${DEBZ_ZFS_DATA_DISKS}}"
  [[ -n "${DEBZ_ZFS_SPECIAL_DISKS:-}" ]] && _ok "Special:"   "${DEBZ_ZFS_SPECIAL_DISKS}"
  _ok "ZFS:"       "${DEBZ_STORAGE_MODE}${DEBZ_ZFS_ENCRYPT:+  · encrypted}"
  _ok "Keyboard:"  "${DEBZ_KEYBOARD_LAYOUT}${DEBZ_KEYBOARD_VARIANT:+ / ${DEBZ_KEYBOARD_VARIANT}}"
  _ok "Locale:"    "${DEBZ_LOCALE}"
  _ok "Timezone:"  "${DEBZ_TIMEZONE}"
  _ok "Network:"   "${DEBZ_NET_METHOD}"
  [[ -n "${DEBZ_EXTRA_PACKAGES}" ]] && _ok "Extras:"   "${DEBZ_EXTRA_PACKAGES}"
  if [[ "${DEBZ_KEEP_DARKSITE:-0}" == "1" ]]; then
    _ok "Updates:"  "custom mirror: ${DEBZ_CUSTOM_MIRROR_URL}"
  else
    _ok "Updates:"  "internet (deb.debian.org)"
  fi
  # Infrastructure mode summary
  _ok "Deploy mode:" "${DEBZ_INFRA_MODE}"
  if [[ "${DEBZ_INFRA_MODE}" == "control-plane" ]]; then
    _ok "Cluster:"   "${DEBZ_CLUSTER_CIDR}  /  ${DEBZ_CLUSTER_SIZE} nodes  /  ${DEBZ_CLUSTER_DOMAIN}"
    _ok "WireGuard:" "wg0 :${DEBZ_WG0_PORT:-51820}  wg1 :${DEBZ_WG1_PORT:-51821}  wg2 :${DEBZ_WG2_PORT:-51822}  wg3 :${DEBZ_WG3_PORT:-51823}"
    if [[ -n "${DEBZ_AWS_ACCESS_KEY_ID:-}"  ]]; then _ok "AWS:"     "${DEBZ_AWS_REGION}"; fi
    if [[ -n "${DEBZ_AZURE_SUBSCRIPTION_ID:-}" ]]; then _ok "Azure:" "${DEBZ_AZURE_SUBSCRIPTION_ID:0:8}…"; fi
    if [[ -n "${DEBZ_GCP_PROJECT_ID:-}"    ]]; then _ok "GCP:"     "${DEBZ_GCP_PROJECT_ID}"; fi
  fi
  echo
  _warn "This will permanently ERASE ${DEBZ_DISK}. There is no undo."
  echo
  v="$(_ask "Type 'yes' to begin installation")"
  [[ "${v}" == "yes" ]] || { _err "Aborted."; exit 1; }
}


main() {
  local mode="guided" cfg=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --guided) mode="guided"; shift ;;
      --config) cfg="${2:?missing config path}"; mode="config"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      *) k_die "unknown argument: $1" ;;
    esac
  done

  mkdir -p "${DEBZ_LOG_DIR}"
  for _l in debz-installer storage zfs security network bootstrap bootloader; do
    : > "${DEBZ_LOG_DIR}/${_l}.log"
  done

  [[ "${mode}" == "config" ]] && k_answers_load_env_file "${cfg}" || guided_prompt

  k_save_effective_config
  k_preflight

  k_install_zfs_storage

  export DEBZ_PART_ROOT="${DEBZ_PART_ROOT:-${DEBZ_ROOT_PART:-}}"
  export DEBZ_ROOT_PART="${DEBZ_ROOT_PART:-${DEBZ_PART_ROOT:-}}"
  export DEBZ_PART_EFI="${DEBZ_PART_EFI:-${DEBZ_EFI_PART:-}}"
  export DEBZ_EFI_PART="${DEBZ_EFI_PART:-${DEBZ_PART_EFI:-}}"

  k_bootstrap_base
  k_configure_network
  k_configure_security
  k_apply_profile
  k_install_tools
  k_write_install_manifest
  k_seed_ca
  k_enable_firstboot
  k_install_bootloader

  # Copy live session state DB to target if it exists
  if [[ -f "/var/lib/debz/state.db" ]]; then
    k_log "Copying live session state.db to target..."
    mkdir -p "${DEBZ_TARGET_MNT}/var/lib/debz"
    cp "/var/lib/debz/state.db" "${DEBZ_TARGET_MNT}/var/lib/debz/state.db"
    k_log "State DB copied ($(du -sh /var/lib/debz/state.db | cut -f1))"
  fi

  # Take initial @install snapshot across all rpool datasets for instant rollback
  k_log "Taking initial @install snapshot..."
  local _snap_ts
  _snap_ts=$(date -u +%Y%m%dT%H%M%SZ)
  # Snapshot every rpool dataset recursively — this creates the factory-fresh restore point
  zfs snapshot -r "rpool@install-${_snap_ts}" 2>/dev/null && \
    k_log "  rpool@install-${_snap_ts} — recursive snapshot OK" || \
    k_log "  WARN: rpool recursive snapshot failed (non-fatal)"
  zfs snapshot -r "bpool@install-${_snap_ts}" 2>/dev/null && \
    k_log "  bpool@install-${_snap_ts} — recursive snapshot OK" || \
    k_log "  WARN: bpool recursive snapshot failed (non-fatal)"
  k_log "Initial snapshot complete — system can be rolled back to this point at any time"

  k_log "Install complete"
  k_poweroff_after_success
  sync || true
}

main "$@"
