// debz: keep kernel headers installed so DKMS can always rebuild ZFS modules
// when a new kernel is installed via apt upgrade.
//
// Without linux-headers-amd64 (the meta-package that tracks the current kernel),
// DKMS has no build environment and ZFS modules will fail to compile for the
// new kernel — leaving the system unbootable if ZFS is on root.

APT::NeverAutoRemove {
    "linux-headers-amd64";
    "linux-headers-arm64";
    "linux-image-amd64";
    "linux-image-arm64";
};

// Keep the DKMS source package for ZFS — removing it would mean no rebuild
// capability after a kernel upgrade.
APT::NeverAutoRemove {
    "zfs-dkms";
};
