#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# debz-recovery — recovery mode tool for Debz
# Usage:
#   debz-recovery import [pool]
#   debz-recovery list-be
#   debz-recovery list-snapshots <dataset>
#   debz-recovery activate <snapshot>
#   debz-recovery rollback <snapshot>
#   debz-recovery chroot
#   debz-recovery export-logs <dest>
#   debz-recovery reinstall-bootloader <disk>
# ---------------------------------------------------------------------------

PROGNAME="$(basename "$0")"

log() {
    echo "[$(date '+%Y-%m-%dT%H:%M:%S')] [$PROGNAME] $*" >&2
}

die() {
    log "ERROR: $*"
    exit 1
}

usage() {
    cat <<EOF
Usage: $PROGNAME <command> [args]

Commands:
  import [pool]                 Import a ZFS pool for recovery (default: rpool)
  list-be                       List available boot environments
  list-snapshots <dataset>      List snapshots of a dataset
  activate <snapshot>           Set bootfs to the dataset of <snapshot>
  rollback <snapshot>           Roll back a dataset to <snapshot>
  chroot                        Enter a chroot into the imported pool root
  export-logs <dest>            Copy installer/debz logs to <dest>
  reinstall-bootloader <disk>   Reinstall ZFSBootMenu on <disk>

Most operations require root.

Examples:
  $PROGNAME import rpool
  $PROGNAME list-be
  $PROGNAME list-snapshots rpool/ROOT/default
  $PROGNAME activate rpool/ROOT/default@my-snapshot
  $PROGNAME rollback rpool/ROOT/default@broken-update
  $PROGNAME chroot
  $PROGNAME export-logs /mnt/usb/logs
  $PROGNAME reinstall-bootloader /dev/sda
EOF
}

# ---------------------------------------------------------------------------
# Locate and source recovery.sh and common.sh
# ---------------------------------------------------------------------------

RECOVERY_LIB=""
CANDIDATES=(
    "/usr/lib/debz-installer/backend/recovery.sh"
    "$(dirname "$(dirname "$(realpath "$0")")")/recovery.sh"
    "/root/debz/installer/backend/recovery.sh"
)

for candidate in "${CANDIDATES[@]}"; do
    if [[ -f "$candidate" ]]; then
        RECOVERY_LIB="$candidate"
        break
    fi
done

[[ -n "$RECOVERY_LIB" ]] \
    || die "recovery.sh not found. Checked: ${CANDIDATES[*]}"

COMMON_LIB="$(dirname "$RECOVERY_LIB")/common.sh"
[[ -f "$COMMON_LIB" ]] \
    || die "common.sh not found at $COMMON_LIB"

# shellcheck source=../common.sh
source "$COMMON_LIB"
# shellcheck source=../recovery.sh
source "$RECOVERY_LIB"

# ---------------------------------------------------------------------------
# Commands that DON'T require root
# ---------------------------------------------------------------------------

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
    help|--help|-h|"")
        usage
        exit 0
        ;;
esac

# ---------------------------------------------------------------------------
# All remaining commands require root
# ---------------------------------------------------------------------------

[[ "$(id -u)" -eq 0 ]] \
    || die "debz-recovery requires root. Run with sudo or as root."

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

case "$COMMAND" in
    import)
        POOL="${1:-rpool}"
        recovery_import_pool "$POOL"
        ;;

    list-be)
        recovery_list_bootenvs
        ;;

    list-snapshots)
        DATASET="${1:-}"
        [[ -n "$DATASET" ]] \
            || die "list-snapshots requires a dataset argument. Example: rpool/ROOT/default"
        recovery_list_snapshots "$DATASET"
        ;;

    activate)
        SNAP="${1:-}"
        [[ -n "$SNAP" ]] \
            || die "activate requires a snapshot argument."
        recovery_activate_bootenv "$SNAP"
        log "Next boot will use: ${SNAP%%@*}"
        ;;

    rollback)
        SNAP="${1:-}"
        [[ -n "$SNAP" ]] \
            || die "rollback requires a snapshot argument."
        log "WARNING: Rolling back will DISCARD all changes made after $SNAP."
        log "Press Ctrl+C within 5 seconds to abort..."
        sleep 5
        recovery_rollback "$SNAP"
        log "Rollback complete. Reboot to apply."
        ;;

    chroot)
        TARGET="${1:-${RECOVERY_MOUNT}}"
        recovery_chroot "$TARGET"
        ;;

    export-logs)
        DEST="${1:-}"
        [[ -n "$DEST" ]] \
            || die "export-logs requires a destination argument. Example: /mnt/usb/logs"
        recovery_export_logs "$DEST"
        ;;

    reinstall-bootloader)
        DISK="${1:-}"
        [[ -n "$DISK" ]] \
            || die "reinstall-bootloader requires a disk argument. Example: /dev/sda"
        [[ -b "$DISK" ]] \
            || die "Not a block device: $DISK"
        TARGET="${2:-${RECOVERY_MOUNT}}"
        recovery_reinstall_bootloader "$TARGET" "$DISK"
        ;;

    *)
        usage
        die "Unknown command: '$COMMAND'"
        ;;
esac
