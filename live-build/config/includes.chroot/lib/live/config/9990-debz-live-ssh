#!/bin/sh
set -eu

LOG=/var/log/debz-live-ssh.log
exec >>"$LOG" 2>&1

echo "=== debz live ssh setup start ==="
date

USER_NAME="live"
USER_PASS="live"

if id "$USER_NAME" >/dev/null 2>&1; then
  echo "$USER_NAME:$USER_PASS" | chpasswd
  echo "password set for $USER_NAME"
else
  echo "user $USER_NAME does not exist yet"
fi

mkdir -p /run/sshd
chmod 0755 /run/sshd

echo "=== debz live ssh setup end ==="
date
