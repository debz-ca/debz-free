#!/bin/sh
# Clean stale Firefox lock files from the live profile so Firefox always
# starts cleanly on boot without "already running" errors.
set -eu

PROFILE_DIR="/home/live/.mozilla/firefox/debz.default"
mkdir -p "$PROFILE_DIR"
rm -f "$PROFILE_DIR/lock" "$PROFILE_DIR/.parentlock"
chown -R live:live /home/live/.mozilla 2>/dev/null || true
