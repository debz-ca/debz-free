// Debz APT pre-transaction snapshot hook
// Placed at: /etc/apt/apt.conf.d/00-debz-snapshot-pre
// Creates a ZFS snapshot of rpool/ROOT/default before APT update or dpkg transactions.

APT::Update::Pre-Invoke {"/usr/local/sbin/snapshot-create.sh apt-pre";};
DPkg::Pre-Invoke {"/usr/local/sbin/snapshot-create.sh apt-pre";};
