# cloud-credentials.env — copy to /etc/debz/cloud-credentials.env and fill in
# Sourced by debz-spawn for Proxmox, AWS, GCP, Azure deploys.
# Mode 0600 — never commit this file.

# ── Proxmox ──────────────────────────────────────────────────────────────────
PROXMOX_HOST=proxmox.debz.local
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=
PROXMOX_DATA_STORE=local-lvm
PROXMOX_NODE=pve

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_SUBNET_ID=subnet-xxxxxxxx
AWS_SECURITY_GROUP_ID=sg-xxxxxxxx
AWS_KEY_NAME=debz
AWS_INSTANCE_TYPE=t3.medium
AWS_BUCKET=my-debz-amis

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT=my-project
GCP_ZONE=us-central1-a
GCP_REGION=us-central1
GCP_MACHINE_TYPE=e2-medium

# ── Azure ─────────────────────────────────────────────────────────────────────
AZURE_RESOURCE_GROUP=debz
AZURE_LOCATION=eastus
AZURE_VM_SIZE=Standard_B2s
