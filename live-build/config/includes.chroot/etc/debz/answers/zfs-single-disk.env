# Basic deb+zfs server install — single disk, no encryption.
# DEBZ_DISK left blank so debz-autoinstall auto-detects the first available disk
# (/dev/sda, /dev/vda, /dev/nvme0n1 in that order).
# Set explicitly if the target has multiple disks and you need a specific one.
DEBZ_PROFILE=server
DEBZ_STORAGE_MODE=zfs
DEBZ_ENABLE_ZFS=1
DEBZ_ENABLE_EBPF=0
DEBZ_DISK=
DEBZ_HOSTNAME=debz
DEBZ_USERNAME=admin
DEBZ_PASSWORD=changeme
DEBZ_ROOT_PASSWORD=changeme
DEBZ_NET_METHOD=dhcp
DEBZ_ZFS_ENCRYPT=0
DEBZ_ZFS_TOPOLOGY=single
DEBZ_ZFS_ASHIFT=12
DEBZ_FORCE_WIPE=1
DEBZ_TIMEZONE=UTC
DEBZ_LOCALE=en_US.UTF-8
DEBZ_KEYBOARD_LAYOUT=us
