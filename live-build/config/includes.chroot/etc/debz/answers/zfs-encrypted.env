DEBZ_PROFILE=server
DEBZ_STORAGE_MODE=zfs
DEBZ_ENABLE_ZFS=1
DEBZ_ENABLE_EBPF=1
DEBZ_DISK=/dev/sda
DEBZ_HOSTNAME=debz-secure
DEBZ_USERNAME=admin
DEBZ_PASSWORD=changeme
DEBZ_ROOT_PASSWORD=changeme
DEBZ_NET_METHOD=dhcp
DEBZ_ZFS_ENCRYPT=1
DEBZ_ZFS_PASSPHRASE=changemezfs
DEBZ_ZFS_BPOOL_SIZE_MIB=2048
DEBZ_ZFS_ASHIFT=12
DEBZ_FORCE_WIPE=1
