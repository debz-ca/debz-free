# debz I/O scheduler tuning
# NVMe / non-rotational: use 'none' (no scheduler overhead, hardware queues handle it)
# Rotational HDD: use 'bfq' (fair queuing, better latency under mixed read/write load)

ACTION=="add|change", KERNEL=="nvme[0-9]*", ATTR{queue/scheduler}="none"
ACTION=="add|change", KERNEL=="sd[a-z]|vd[a-z]", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="none"
ACTION=="add|change", KERNEL=="sd[a-z]|vd[a-z]", ATTR{queue/rotational}=="1", ATTR{queue/scheduler}="bfq"
