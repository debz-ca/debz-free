#!/bin/sh
# Set system-level defaults to suppress first-run nag dialogs.
set -e

# Set gnome-terminal as the default x-terminal-emulator so GNOME Terminal
# does not show the "Set as your default terminal?" dialog on first launch.
if update-alternatives --list x-terminal-emulator 2>/dev/null | grep -q gnome-terminal; then
    update-alternatives --set x-terminal-emulator \
        "$(update-alternatives --list x-terminal-emulator | grep gnome-terminal | head -1)"
fi
